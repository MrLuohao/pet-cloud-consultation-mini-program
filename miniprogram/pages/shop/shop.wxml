<!--
  ╔══════════════════════════════════════════════════════════════════════════════
  ║  商城页面 | Shop Page                                                            ║
  ║  Design: Modern • Fluid • Interactive                                            ║
  ╚══════════════════════════════════════════════════════════════════════════════
-->
<view class="shop-page">
  <!-- 装饰背景 -->
  <view class="shop-bg-decor">
    <view class="shop-orb shop-orb-1"></view>
    <view class="shop-orb shop-orb-2"></view>
    <view class="shop-orb shop-orb-3"></view>
  </view>

  <!-- 购物车快捷按钮 -->
  <movable-area class="cart-movable-area">
    <movable-view class="cart-movable-view" x="{{cartX}}" y="{{cartY}}" direction="all" bindchange="onCartChange">
      <view class="cart-float-btn" bindtap="goToCart">
        <view class="cart-pulse-ring"></view>
        <view class="cart-pulse-ring delay"></view>
        <text class="cart-icon">🛒</text>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">
          <text>{{cartCount > 99 ? '99+' : cartCount}}</text>
        </view>
      </view>
    </movable-view>
  </movable-area>

  <!-- 主内容区 -->
  <scroll-view
    class="main-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onLoadMore"
  >
    <!-- 分类选择器 -->
    <view class="category-section">
      <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="category-list">
          <view
            class="category-item {{activeCategory === index ? 'active' : ''}}"
            wx:for="{{categories}}"
            wx:key="index"
            bindtap="onCategoryChange"
            data-index="{{index}}"
          >
            <view class="category-icon-wrap">
              <text class="category-icon">{{item.icon}}</text>
              <view class="category-glow" wx:if="{{activeCategory === index}}"></view>
            </view>
            <text class="category-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 推荐Banner -->
    <view class="promo-banner" bindtap="onPromoTap" wx:if="{{promoBanner}}">
      <view class="promo-bg">
        <view class="promo-gradient"></view>
        <view class="promo-particle promo-particle-1"></view>
        <view class="promo-particle promo-particle-2"></view>
        <view class="promo-particle promo-particle-3"></view>
      </view>
      <view class="promo-content">
        <view class="promo-tag">
          <view class="promo-tag-dot"></view>
          <text>限时特惠</text>
        </view>
        <text class="promo-title">{{promoBanner.title}}</text>
        <text class="promo-desc">{{promoBanner.desc}}</text>
      </view>
      <view class="promo-emoji-wrap">
        <text class="promo-emoji">{{promoBanner.emoji}}</text>
      </view>
    </view>

    <!-- 商品区域 -->
    <view class="product-section">
      <view class="product-section-header">
        <text class="product-section-title">精选好物</text>
        <text class="product-section-sub">为您的爱宠精心挑选</text>
      </view>
      <view class="product-grid">
        <view
          class="product-card"
          wx:for="{{products}}"
          wx:key="id"
          bindtap="onProductTap"
          data-product="{{item}}"
          hover-class="product-card-hover"
        >
          <view class="product-image-container">
            <view class="product-bg product-bg-{{item.color || index % 5}}">
              <image wx:if="{{item.coverUrl}}" class="product-image" src="{{item.coverUrl}}" mode="aspectFill"></image>
              <text wx:else class="product-emoji">{{item.emoji}}</text>
            </view>
            <view class="product-badge" wx:if="{{item.badge}}">
              <text>{{item.badge}}</text>
            </view>
            <view class="product-favorite" catchtap="onFavorite" data-id="{{item.id}}">
              <text>{{item.favorited ? '❤️' : '🤍'}}</text>
            </view>
            <view class="product-shine"></view>
          </view>
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <view class="product-meta">
              <view class="product-price-row">
                <text class="price-symbol">¥</text>
                <text class="product-price">{{item.price}}</text>
                <text class="product-original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
              </view>
              <text class="product-sales">已售{{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 骨架屏 -->
    <view class="skeleton-grid" wx:if="{{loading && products.length === 0}}">
      <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="index">
        <view class="skeleton skeleton-img"></view>
        <view class="skeleton-info">
          <view class="skeleton skeleton-title"></view>
          <view class="skeleton skeleton-price"></view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{products.length === 0 && !loading}}">
      <view class="empty-illustration">
        <text class="empty-emoji">📦</text>
        <view class="empty-ring empty-ring-1"></view>
        <view class="empty-ring empty-ring-2"></view>
      </view>
      <text class="empty-title">暂无商品</text>
      <text class="empty-desc">换个分类看看吧</text>
    </view>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loading && products.length > 0}}">
      <view class="load-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && products.length > 0}}">
      <view class="no-more-line"></view>
      <text class="no-more-text">没有更多了</text>
      <view class="no-more-line"></view>
    </view>

    <view class="tabbar-safe"></view>
  </scroll-view>
</view>
