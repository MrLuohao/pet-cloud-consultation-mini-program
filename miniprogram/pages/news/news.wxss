/**
 * ╔══════════════════════════════════════════════════════════════════════════════
 * ║  消息中心样式 | Message Center Styles                                         ║
 * ║  Design: Modern • Glass • Interactive                                       ║
 * ╚══════════════════════════════════════════════════════════════════════════════
 */

/* ==================== 页面容器 ==================== */
.news-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0EBFF 0%, #F7F5FF 30%, #F8F8F8 60%);
  position: relative;
  overflow: hidden;
}

/* ==================== 装饰背景 ==================== */
.news-bg-decor {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.news-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.35;
}

.news-orb-1 {
  width: 350rpx; height: 350rpx;
  background: radial-gradient(circle, var(--primary-200) 0%, transparent 70%);
  top: -80rpx; right: -60rpx;
  animation: newsOrbFloat1 8s ease-in-out infinite;
}

.news-orb-2 {
  width: 280rpx; height: 280rpx;
  background: radial-gradient(circle, #BFDBFE 0%, transparent 70%);
  top: 50%; left: -50rpx;
  animation: newsOrbFloat2 10s ease-in-out infinite;
}

@keyframes newsOrbFloat1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-20rpx, 15rpx) scale(1.08); }
}
@keyframes newsOrbFloat2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(15rpx, -20rpx) scale(1.05); }
}

/* ==================== 页面头部 ==================== */
.news-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-6);
  padding-top: calc(var(--space-4) + env(safe-area-inset-top));
  background: rgba(255,255,255,0.75);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1rpx solid rgba(255,255,255,0.6);
  position: relative;
  z-index: 2;
}

.header-title {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.header-action {
  display: flex;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  background: var(--primary-50);
  border-radius: var(--radius-full);
  transition: all var(--duration-200) var(--ease-default);
}

.header-action:active {
  transform: scale(0.95);
  background: var(--primary-100);
}

.action-text {
  font-size: var(--font-sm);
  font-weight: var(--font-medium);
  color: var(--primary-600);
}

/* ==================== 主滚动区 ==================== */
.main-scroll {
  height: calc(100vh - 100rpx - env(safe-area-inset-top));
  position: relative;
  z-index: 1;
}

/* ==================== 快捷入口区域 ==================== */
.quick-entry-section {
  padding: var(--space-5) var(--space-6);
  margin: var(--space-3) var(--space-4);
  background: rgba(255,255,255,0.75);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-radius: var(--radius-2xl);
  box-shadow: 0 4rpx 20rpx rgba(109,50,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.6);
}

.quick-entry-list {
  display: flex;
  justify-content: space-around;
}

.quick-entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  position: relative;
}

.quick-entry-icon {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: 48rpx;
  transition: transform var(--duration-200) var(--ease-default);
}

.quick-entry-item:active .quick-entry-icon {
  transform: scale(0.9);
}

.ai-icon {
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
}

.service-icon {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.consult-icon {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.entry-glow {
  position: absolute;
  inset: -6rpx;
  border-radius: var(--radius-2xl);
  opacity: 0.2;
  filter: blur(10rpx);
}

.ai-icon .entry-glow { background: #C7D2FE; }
.service-icon .entry-glow { background: #BFDBFE; }
.consult-icon .entry-glow { background: #A7F3D0; }

.quick-entry-name {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
}

.quick-entry-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 var(--space-2);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--error);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  color: white;
  font-weight: var(--font-semibold);
}

/* ==================== 通用区块容器 ==================== */
.section-container {
  padding: var(--space-4) var(--space-6);
  margin: 0 var(--space-4) var(--space-3);
  background: rgba(255,255,255,0.75);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-radius: var(--radius-2xl);
  box-shadow: 0 4rpx 20rpx rgba(109,50,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.6);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.section-more text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.more-arrow {
  transition: transform var(--duration-200) var(--ease-default);
}

.section-more:active .more-arrow {
  transform: translateX(4rpx);
}

/* ==================== 会话列表 ==================== */
.conversation-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.conversation-item {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4);
  background: rgba(255,255,255,0.5);
  border-radius: var(--radius-xl);
  transition: all var(--duration-200) var(--ease-default);
  border: 1rpx solid rgba(255,255,255,0.4);
}

.conversation-item-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(109,50,255,0.08);
}

.conversation-avatar-wrapper {
  position: relative;
  flex-shrink: 0;
}

.conversation-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--bg-tertiary);
}

.conversation-avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary-600);
}

.conversation-avatar-placeholder.ai-bg {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  font-size: 40rpx;
}

.conversation-online-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 20rpx;
  height: 20rpx;
  background: #10B981;
  border-radius: 50%;
  border: 3rpx solid var(--bg-elevated);
}

.conversation-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  min-width: 0;
}

.conversation-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.conversation-name-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.conversation-name {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.conversation-pin {
  padding: 2rpx var(--space-2);
  background: var(--primary-100);
  border-radius: var(--radius-sm);
}

.conversation-pin text {
  font-size: 20rpx;
  color: var(--primary-600);
}

.conversation-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.conversation-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.conversation-message {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.conversation-unread {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 var(--space-2);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--error);
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-left: var(--space-2);
}

.conversation-unread text {
  font-size: 22rpx;
  color: white;
  font-weight: var(--font-semibold);
}

/* ==================== 系统通知列表 ==================== */
.notification-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-4);
}

.notification-item {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4);
  background: rgba(255,255,255,0.5);
  border-radius: var(--radius-xl);
  transition: all var(--duration-200) var(--ease-default);
  border: 1rpx solid rgba(255,255,255,0.4);
}

.notification-item-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(109,50,255,0.08);
}

.notification-icon-wrapper {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.notification-purple {
  background: linear-gradient(135deg, var(--primary-100) 0%, var(--primary-200) 100%);
}

.notification-blue {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.notification-green {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.notification-orange {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.notification-pink {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.notification-cyan {
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
}

.notification-icon {
  font-size: 36rpx;
}

.notification-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--error);
  border-radius: 50%;
  border: 2rpx solid var(--bg-secondary);
}

.notification-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  min-width: 0;
}

.notification-title {
  font-size: var(--font-sm);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.notification-desc {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-arrow {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  flex-shrink: 0;
  transition: transform var(--duration-200) var(--ease-default);
}

.notification-item-hover .notification-arrow {
  transform: translateX(4rpx);
}

/* ==================== 通知分类 ==================== */
.notification-categories {
  display: flex;
  justify-content: space-around;
  padding-top: var(--space-4);
  border-top: 1rpx solid rgba(109,50,255,0.08);
}

.notification-category {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  position: relative;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: 36rpx;
}

.order-bg {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.activity-bg {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.system-bg {
  background: linear-gradient(135deg, var(--primary-100) 0%, var(--primary-200) 100%);
}

.category-name {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.category-count {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 var(--space-1);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--error);
  border-radius: var(--radius-full);
  font-size: 20rpx;
  color: white;
  font-weight: var(--font-semibold);
}

/* ==================== 操作弹窗 ==================== */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.action-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.9);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform var(--duration-300) var(--ease-out);
  z-index: 1000;
}

.action-sheet-show {
  transform: translateY(0);
}

.action-sheet-item {
  padding: var(--space-5) var(--space-6);
  text-align: center;
  border-bottom: 1rpx solid var(--border-subtle);
}

.action-sheet-item text {
  font-size: var(--font-base);
  color: var(--text-primary);
}

.action-sheet-item.danger text {
  color: var(--error);
}

.action-sheet-item:active {
  background: var(--bg-secondary);
}

.action-sheet-cancel {
  padding: var(--space-5) var(--space-6);
  text-align: center;
  margin-top: var(--space-2);
  background: var(--bg-secondary);
}

.action-sheet-cancel text {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.action-sheet-cancel:active {
  background: var(--bg-tertiary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-20) var(--space-8);
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-6);
}

.empty-emoji {
  font-size: 100rpx;
  z-index: 2;
}

.empty-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(109,50,255,0.15);
  animation: ringPulse 3s ease-in-out infinite;
}

.empty-ring-1 {
  width: 160rpx;
  height: 160rpx;
  animation-delay: 0s;
}

.empty-ring-2 {
  width: 200rpx;
  height: 200rpx;
  animation-delay: 0.5s;
}

@keyframes ringPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.3;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.5;
  }
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--space-6);
}

.empty-btn {
  padding: var(--space-3) var(--space-6);
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  box-shadow: 0 8rpx 24rpx rgba(109,50,255,0.25);
  transition: all var(--duration-300) var(--ease-default);
}

.empty-btn:active {
  transform: scale(0.95);
}

.empty-btn text {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-inverse);
}

/* ==================== 动画 ==================== */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: slideUp 0.6s var(--ease-out) backwards;
}

.stagger-0 { animation-delay: 0s; }
.stagger-1 { animation-delay: 0.1s; }
.stagger-2 { animation-delay: 0.2s; }

/* ==================== 底部安全区 ==================== */
.tabbar-safe {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
