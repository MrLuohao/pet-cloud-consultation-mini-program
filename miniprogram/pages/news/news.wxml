<!--
  ╔══════════════════════════════════════════════════════════════════════════════
  ║  消息中心 | Message Center                                                    ║
  ║  Design: Modern • Fluid • Interactive                                       ║
  ╚══════════════════════════════════════════════════════════════════════════════
-->
<view class="news-page">
  <!-- 装饰背景 -->
  <view class="news-bg-decor">
    <view class="news-orb news-orb-1"></view>
    <view class="news-orb news-orb-2"></view>
  </view>

  <!-- 页面头部 -->
  <view class="news-header">
    <text class="header-title">消息中心</text>
    <view class="header-action" bindtap="onReadAll" wx:if="{{totalUnreadCount > 0}}">
      <text class="action-text">全部已读</text>
    </view>
  </view>

  <!-- 主内容区 -->
  <scroll-view class="main-scroll" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled refresher-triggered="{{isRefreshing}}" bindrefresherrefresh="onRefresh">
    <!-- 快捷入口 -->
    <view class="quick-entry-section animate-fade-in-up">
      <view class="quick-entry-list">
        <!-- AI助手 -->
        <view class="quick-entry-item" bindtap="goToAiChat">
          <view class="quick-entry-icon ai-icon">
            <text>🤖</text>
            <view class="entry-glow"></view>
          </view>
          <text class="quick-entry-name">AI助手</text>
          <view class="quick-entry-badge" wx:if="{{aiUnreadCount > 0}}">{{aiUnreadCount > 99 ? '99+' : aiUnreadCount}}</view>
        </view>
        <!-- 在线客服 -->
        <view class="quick-entry-item" bindtap="goToCustomerService">
          <view class="quick-entry-icon service-icon">
            <text>👨‍⚕️</text>
            <view class="entry-glow"></view>
          </view>
          <text class="quick-entry-name">在线客服</text>
        </view>
        <!-- 我的咨询 -->
        <view class="quick-entry-item" bindtap="goToConsultation">
          <view class="quick-entry-icon consult-icon">
            <text>💬</text>
            <view class="entry-glow"></view>
          </view>
          <text class="quick-entry-name">我的咨询</text>
          <view class="quick-entry-badge" wx:if="{{consultationUnreadCount > 0}}">{{consultationUnreadCount > 99 ? '99+' : consultationUnreadCount}}</view>
        </view>
      </view>
    </view>

    <!-- 会话列表 -->
    <view class="section-container" wx:if="{{conversations.length > 0}}">
      <view class="section-header">
        <text class="section-title">最近会话</text>
      </view>
      <view class="conversation-list">
        <view
          class="conversation-item animate-fade-in-up stagger-{{index % 3}}"
          wx:for="{{conversations}}"
          wx:key="id"
          bindtap="onConversationTap"
          bindlongpress="onConversationLongPress"
          data-conversation="{{item}}"
          hover-class="conversation-item-hover"
        >
          <view class="conversation-avatar-wrapper">
            <image wx:if="{{item.targetAvatar}}" class="conversation-avatar" src="{{item.targetAvatar}}" mode="aspectFill"></image>
            <view wx:elif="{{item.type === 'ai_chat'}}" class="conversation-avatar-placeholder ai-bg">🤖</view>
            <view wx:else class="conversation-avatar-placeholder">{{item.targetName ? item.targetName[0] : '宠'}}</view>
            <view class="conversation-online-dot" wx:if="{{item.type === 'ai_chat'}}"></view>
          </view>
          <view class="conversation-content">
            <view class="conversation-header">
              <view class="conversation-name-row">
                <text class="conversation-name">{{item.targetName}}</text>
                <view class="conversation-pin" wx:if="{{item.isPinned}}">
                  <text>置顶</text>
                </view>
              </view>
              <text class="conversation-time">{{item.lastMessageTimeStr}}</text>
            </view>
            <view class="conversation-footer">
              <text class="conversation-message">{{item.lastMessage || '暂无消息'}}</text>
              <view class="conversation-unread" wx:if="{{item.unreadCount > 0}}">
                <text>{{item.unreadCount > 99 ? '99+' : item.unreadCount}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 系统通知 -->
    <view class="section-container">
      <view class="section-header">
        <text class="section-title">系统通知</text>
        <view class="section-more" bindtap="goToNotifications">
          <text>查看全部</text>
          <text class="more-arrow">→</text>
        </view>
      </view>
      <view class="notification-list">
        <view
          class="notification-item animate-fade-in-up stagger-{{index % 3}}"
          wx:for="{{recentNotifications}}"
          wx:key="id"
          bindtap="onNotificationTap"
          data-notification="{{item}}"
          hover-class="notification-item-hover"
        >
          <view class="notification-icon-wrapper notification-{{item.color || 'purple'}}">
            <text class="notification-icon">{{item.icon || '📄'}}</text>
            <view class="notification-dot" wx:if="{{item.isRead === 0}}"></view>
          </view>
          <view class="notification-info">
            <view class="notification-header">
              <text class="notification-title">{{item.title}}</text>
            </view>
            <text class="notification-desc">{{item.content}}</text>
          </view>
          <view class="notification-arrow">→</view>
        </view>
      </view>

      <!-- 通知分类快捷入口 -->
      <view class="notification-categories">
        <view class="notification-category" bindtap="goToNotificationType" data-type="order">
          <view class="category-icon order-bg">
            <text>📦</text>
          </view>
          <text class="category-name">订单通知</text>
          <view class="category-count" wx:if="{{notificationCounts.orderCount > 0}}">{{notificationCounts.orderCount}}</view>
        </view>
        <view class="notification-category" bindtap="goToNotificationType" data-type="activity">
          <view class="category-icon activity-bg">
            <text>🎁</text>
          </view>
          <text class="category-name">活动通知</text>
          <view class="category-count" wx:if="{{notificationCounts.activityCount > 0}}">{{notificationCounts.activityCount}}</view>
        </view>
        <view class="notification-category" bindtap="goToNotificationType" data-type="system">
          <view class="category-icon system-bg">
            <text>🔔</text>
          </view>
          <text class="category-name">系统消息</text>
          <view class="category-count" wx:if="{{notificationCounts.systemCount > 0}}">{{notificationCounts.systemCount}}</view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{conversations.length === 0 && recentNotifications.length === 0}}">
      <view class="empty-illustration">
        <text class="empty-emoji">📬</text>
        <view class="empty-ring empty-ring-1"></view>
        <view class="empty-ring empty-ring-2"></view>
      </view>
      <text class="empty-title">暂无消息</text>
      <text class="empty-desc">消息通知会显示在这里</text>
      <view class="empty-btn" bindtap="goToIndex">
        <text>去逛逛</text>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="tabbar-safe"></view>
  </scroll-view>

  <!-- 长按操作弹窗 -->
  <view class="action-sheet-mask" wx:if="{{showActionSheet}}" bindtap="hideActionSheet"></view>
  <view class="action-sheet {{showActionSheet ? 'action-sheet-show' : ''}}">
    <view class="action-sheet-item" bindtap="onActionMarkRead">
      <text>标为已读</text>
    </view>
    <view class="action-sheet-item" bindtap="onActionTogglePin">
      <text>{{selectedConversation && selectedConversation.isPinned ? '取消置顶' : '置顶会话'}}</text>
    </view>
    <view class="action-sheet-item danger" bindtap="onActionDelete">
      <text>删除会话</text>
    </view>
    <view class="action-sheet-cancel" bindtap="hideActionSheet">
      <text>取消</text>
    </view>
  </view>
</view>
