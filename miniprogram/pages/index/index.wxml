<!--
  ╔══════════════════════════════════════════════════════════════════════════════
  ║  伴宠云诊 - 首页 | Home Page                                                      ║
  ║  Design: Modern • Fluid • Interactive                                            ║
  ║  Inspired by: mstand.cn & Framer.com                                             ║
  ╚══════════════════════════════════════════════════════════════════════════════
-->
<view class="index-page">
  <!-- ==================== 主内容区 ==================== -->
  <scroll-view
    class="main-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscroll="onScroll"
    bindscrolltolower="onLoadMore"
  >
    <!-- 搜索栏 -->
    <view class="search-section">
      <view class="search-bar {{searchFocused ? 'search-focused' : ''}}" bindtap="focusSearch" bindlongpress="resetGuide">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索您感兴趣的商品..."
          placeholder-class="search-placeholder"
          value="{{keyword}}"
          bindinput="onSearchInput"
          bindconfirm="onSearch"
          bindfocus="onSearchFocus"
          bindblur="onSearchBlur"
        />
        <view class="search-clear {{keyword ? 'show' : ''}}" bindtap="onClearSearch">
          <text>✕</text>
        </view>
      </view>
    </view>

    <!-- Hero Banner - 炫酷渐变卡片 -->
    <view class="hero-section">
      <view class="hero-card {{heroLoaded ? 'loaded' : ''}}" bindtap="goToDiagnosis">
        <!-- 动态背景装饰 -->
        <view class="hero-bg">
          <view class="hero-gradient animate-gradient-flow"></view>
          <view class="hero-orb hero-orb-1 animate-float"></view>
          <view class="hero-orb hero-orb-2 animate-float" style="animation-delay: 0.5s"></view>
          <view class="hero-orb hero-orb-3 animate-float" style="animation-delay: 1s"></view>
          <!-- 光点粒子 -->
          <view class="hero-particles">
            <view class="particle particle-1"></view>
            <view class="particle particle-2"></view>
            <view class="particle particle-3"></view>
            <view class="particle particle-4"></view>
          </view>
          <view class="hero-grid"></view>
        </view>

        <!-- 内容 -->
        <view class="hero-content">
          <view class="hero-tag animate-fade-in-up">
            <view class="tag-dot"></view>
            <text>AI智能诊断</text>
          </view>
          <view class="hero-title animate-fade-in-up stagger-1">
            <text class="title-line">守护爱宠</text>
            <text class="title-line title-highlight">健康每一天</text>
          </view>
          <view class="hero-desc animate-fade-in-up stagger-2">
            <text>专业医生24小时在线 • AI智能初诊</text>
          </view>
          <view class="hero-actions animate-fade-in-up stagger-3">
            <view class="hero-btn">
              <text>立即体验</text>
              <view class="btn-shine"></view>
            </view>
          </view>
        </view>

        <!-- 宠物装饰（3D浮动效果） -->
        <view class="hero-pet animate-fade-in-up stagger-2">
          <text class="pet-emoji pet-1">🐱</text>
          <text class="pet-emoji pet-2">🐶</text>
          <text class="pet-emoji pet-3">🐰</text>
        </view>
      </view>
    </view>

    <!-- ==================== 宠物档案卡模块 ==================== -->
    <view class="pet-section" wx:if="{{isLoggedIn}}">
      <view class="section-header">
        <text class="section-title">我的宠物</text>
        <view class="section-action">
          <view class="fan-toggle-btn {{fanExpanded ? 'fan-active' : ''}}" wx:if="{{pets.length > 1}}" bindtap="onFanToggleTap">
            <text>{{fanExpanded ? '收起' : '展开'}}</text>
          </view>
          <text class="pet-count" wx:if="{{pets.length > 0}}">{{currentPetIndex + 1}}/{{pets.length}}</text>
          <view class="section-more" bindtap="goToAddPet" wx:if="{{pets.length < 5}}">
            <text class="add-icon">+</text>
            <text>添加</text>
          </view>
        </view>
      </view>

      <!-- 宠物卡片堆叠效果 -->
      <view class="pet-stack-container" wx:if="{{pets.length > 0}}"
        bindtouchstart="onPetTouchStart"
        bindtouchend="onPetTouchEnd"
      >
        <!-- 堆叠的卡片 -->
        <view class="pet-stack {{fanExpanded ? 'fan-mode' : ''}} {{fanAnimating ? 'fan-animating' : ''}}">
          <view
            wx:for="{{pets}}"
            wx:key="id"
            class="pet-card-stack {{index === currentPetIndex ? 'active' : ''}} {{index < currentPetIndex ? 'prev' : ''}} {{index > currentPetIndex ? 'next' : ''}} {{fanExpanded ? 'fan-card' : ''}} {{touchedCardIndex === index ? 'fan-touched' : ''}}"
            style="--card-index: {{index - currentPetIndex}}; --card-z: {{pets.length - index}}; {{fanExpanded ? fanCardStyles[index] : ''}}"
            bindtap="onPetCardTap"
            bindtouchstart="onFanCardTouchStart"
            bindtouchend="onFanCardTouchEnd"
            data-index="{{index}}"
            data-id="{{item.id}}"
          >
            <!-- 大头照区域 -->
            <view class="pet-photo-section">
              <image
                wx:if="{{item.avatarUrl}}"
                class="pet-photo"
                src="{{item.avatarUrl}}"
                mode="aspectFill"
              />
              <view wx:else class="pet-photo pet-photo-placeholder">
                <text class="pet-photo-emoji">{{item.type === 2 ? '🐱' : item.type === 1 ? '🐶' : '🐾'}}</text>
              </view>
              <!-- 性别标签 -->
              <view class="pet-gender-badge {{item.gender === 1 ? 'male' : item.gender === 2 ? 'female' : 'unknown'}}">
                <text class="gender-icon">{{item.genderIcon}}</text>
              </view>
            </view>

            <!-- 信息区域 -->
            <view class="pet-info-section">
              <view class="pet-header-row">
                <text class="pet-name-new">{{item.name}}</text>
                <view class="pet-age-badge" wx:if="{{item.age}}">
                  <text>{{item.age}}</text>
                </view>
              </view>

              <text class="pet-breed-new">{{item.breed || '未知品种'}}</text>

              <!-- 性格标签 -->
              <view class="pet-personality-row" wx:if="{{item.personality}}">
                <text class="personality-label">性格</text>
                <text class="personality-value">{{item.personality}}</text>
              </view>

              <!-- 座右铭 -->
              <view class="pet-motto-row" wx:if="{{item.motto}}">
                <text class="motto-quote">"</text>
                <text class="motto-text">{{item.motto}}</text>
                <text class="motto-quote">"</text>
              </view>

              <!-- 健康状态 -->
              <view class="pet-health-row">
                <view class="health-badge {{item.healthType}}">
                  <text class="health-dot"></text>
                  <text class="health-label">{{item.healthLabel}}</text>
                </view>
                <view class="pet-weight-badge" wx:if="{{item.weight}}">
                  <text>{{item.weight}}kg</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 底部指示器 -->
        <view class="pet-indicators {{fanExpanded ? 'fan-hidden' : ''}}" wx:if="{{pets.length > 1}}">
          <view
            wx:for="{{pets}}"
            wx:key="id"
            class="pet-indicator {{index === currentPetIndex ? 'active' : ''}}"
            bindtap="onIndicatorTap"
            data-index="{{index}}"
          ></view>
        </view>
      </view>

      <!-- 无宠物时的引导 -->
      <view class="pet-empty-new" wx:if="{{pets.length === 0 && !petsLoading}}">
        <view class="pet-empty-illustration">
          <view class="empty-circle"></view>
          <text class="empty-paw">🐾</text>
        </view>
        <text class="pet-empty-title">还没有添加宠物</text>
        <text class="pet-empty-subtitle">添加您的爱宠，开启健康之旅</text>
        <view class="pet-empty-btn-new" bindtap="goToAddPet">
          <text class="btn-plus">+</text>
          <text>添加宠物</text>
        </view>
      </view>

      <!-- 骨架屏加载 -->
      <view class="pet-skeleton" wx:if="{{petsLoading}}">
        <view class="skeleton skeleton-card"></view>
      </view>
    </view>

    <!-- ==================== 健康提醒模块 ==================== -->
    <view class="reminder-section" wx:if="{{isLoggedIn && reminders.length > 0}}">
      <view class="section-header">
        <text class="section-title">健康提醒</text>
        <view class="reminder-count" wx:if="{{reminders.length > 0}}">
          <text>{{reminders.length}}条待处理</text>
        </view>
      </view>

      <scroll-view class="reminder-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="reminder-list">
          <view
            class="reminder-card card-3d {{item.type}}"
            wx:for="{{reminders}}"
            wx:key="id"
            bindtap="handleReminder"
            data-id="{{item.id}}"
          >
            <view class="reminder-icon-wrapper">
              <text class="reminder-icon">{{item.icon}}</text>
            </view>
            <view class="reminder-content">
              <text class="reminder-title">{{item.title}}</text>
              <text class="reminder-pet">{{item.petName}}</text>
              <text class="reminder-date">{{item.date}}</text>
            </view>
            <view class="reminder-action">
              <text class="action-text">{{item.actionText}}</text>
              <text class="action-arrow">→</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- ==================== 今日任务模块 ==================== -->
    <view class="task-section" wx:if="{{isLoggedIn}}">
      <view class="task-header">
        <text class="section-title">今日任务</text>
        <view class="task-points">
          <text class="task-points-icon">⭐</text>
          <text class="task-points-value">{{totalPoints}}</text>
        </view>
      </view>

      <!-- 任务进度 -->
      <view class="task-progress-bar">
        <view class="task-progress-fill progress-animate" style="width: {{taskProgress}}%"></view>
      </view>

      <!-- 任务列表 -->
      <view class="task-list">
        <view
          class="task-card card-3d {{item.completed ? 'completed' : ''}}"
          wx:for="{{tasks}}"
          wx:key="id"
          bindtap="handleTask"
          data-id="{{item.id}}"
        >
          <view class="task-icon-wrapper {{item.completed ? 'completed' : ''}}">
            <text class="task-icon">{{item.icon}}</text>
            <view class="task-check" wx:if="{{item.completed}}">✓</view>
          </view>
          <view class="task-content">
            <text class="task-name">{{item.name}}</text>
            <text class="task-desc">{{item.desc}}</text>
          </view>
          <view class="task-reward" wx:if="{{!item.completed}}">
            <text class="task-reward-icon">⭐</text>
            <text class="task-reward-value">+{{item.points}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷服务 - 玻璃态卡片 -->
    <view class="quick-section">
      <view class="quick-header">
        <text class="section-title">快速服务</text>
        <view class="section-more" bindtap="handleViewAllServices">
          <text>全部</text>
          <text class="arrow">→</text>
        </view>
      </view>
      <view class="quick-grid">
        <view
          class="quick-card card-3d animate-fade-in-up stagger-{{index}}"
          wx:for="{{quickServices}}"
          wx:key="id"
          bindtap="{{item.action}}"
          hover-class="quick-card-hover"
        >
          <view class="quick-icon-wrapper quick-{{item.color}}">
            <text class="quick-icon">{{item.icon}}</text>
            <view class="quick-glow"></view>
          </view>
          <text class="quick-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 数据展示 -->
    <view class="stats-section">
      <view class="stats-card animate-fade-in-up">
        <view class="stat-item" wx:for="{{stats}}" wx:key="label">
          <text class="stat-value">{{item.value}}</text>
          <text class="stat-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 热门推荐 -->
    <view class="recommend-section">
      <view class="section-header">
        <text class="section-title">精选内容</text>
        <view class="section-tabs">
          <view
            class="tab-item {{activeTab === index ? 'active' : ''}}"
            wx:for="{{tabs}}"
            wx:key="index"
            bindtap="onTabChange"
            data-index="{{index}}"
          >
            <text>{{item}}</text>
            <view class="tab-indicator" wx:if="{{activeTab === index}}"></view>
          </view>
        </view>
      </view>

      <view class="recommend-list">
        <view
          class="recommend-card card-3d card-shine animate-fade-in-up stagger-{{index}}"
          wx:for="{{articles}}"
          wx:key="id"
          bindtap="goToArticleDetail"
          data-id="{{item.id}}"
          hover-class="recommend-card-hover"
        >
          <view class="recommend-cover recommend-cover-{{item.color || index}}">
            <image wx:if="{{item.coverUrl}}" class="cover-image" src="{{item.coverUrl}}" mode="aspectFill" lazy-load></image>
            <text wx:else class="cover-emoji">{{item.emoji || '📄'}}</text>
            <view class="cover-overlay"></view>
          </view>
          <view class="recommend-info">
            <view class="recommend-meta">
              <view class="meta-tag {{item.tagClass || ''}}">{{item.tag}}</view>
              <text class="meta-time">{{item.time}}</text>
            </view>
            <text class="recommend-title">{{item.title}}</text>
            <text class="recommend-desc">{{item.desc}}</text>
            <view class="recommend-footer">
              <view class="footer-stats">
                <text class="stat-item">👁 {{item.views}}</text>
                <text class="stat-item {{item.liked ? 'liked' : ''}}">{{item.liked ? '♥' : '♡'}} {{item.likes}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!loading && articles.length === 0}}">
        <view class="empty-icon-animate">📭</view>
        <text class="empty-title">暂无内容</text>
        <text class="empty-desc">去看看其他精彩内容吧</text>
      </view>

      <!-- 骨架屏加载 -->
      <view class="skeleton-list" wx:if="{{loading && articles.length === 0}}">
        <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="index">
          <view class="skeleton skeleton-cover"></view>
          <view class="skeleton-content">
            <view class="skeleton skeleton-title" style="width: 60%"></view>
            <view class="skeleton skeleton-text" style="width: 80%"></view>
            <view class="skeleton skeleton-text" style="width: 40%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="tabbar-safe"></view>
  </scroll-view>

  <!-- 加载更多 -->
  <view class="load-more {{loading ? 'loading' : ''}}" wx:if="{{hasMore}}">
    <view class="load-spinner" wx:if="{{loading}}"></view>
    <text class="load-text">{{loading ? '加载中...' : '上拉加载更多'}}</text>
  </view>

  <!-- ==================== AI 智能助手悬浮入口（可拖拽） ==================== -->
  <movable-area class="fab-movable-area" wx:if="{{fabInitialized}}">
    <movable-view
      class="fab-movable-view"
      direction="all"
      x="{{fabX}}"
      y="{{fabY}}"
      bindchange="onFabMove"
      bindtouchstart="onFabTouchStart"
      bindtouchend="onFabTouchEnd"
    >
      <view class="ai-fab-container">
        <!-- 快捷菜单 -->
        <view class="ai-fab-menu {{fabMenuOpen ? 'show' : ''}}">
          <view class="fab-menu-item" bindtap="goToDiagnosis" data-type="diagnosis">
            <view class="fab-item-icon diagnosis">
              <text>🏥</text>
            </view>
            <text class="fab-item-text">AI 诊断</text>
          </view>
          <view class="fab-menu-item" bindtap="goToChat" data-type="chat">
            <view class="fab-item-icon chat">
              <text>🤖</text>
            </view>
            <text class="fab-item-text">AI 聊天</text>
          </view>
          <view class="fab-menu-item" bindtap="goToConsultation" data-type="consultation">
            <view class="fab-item-icon consultation">
              <text>👨‍⚕️</text>
            </view>
            <text class="fab-item-text">人工咨询</text>
          </view>
        </view>

        <!-- 主按钮 -->
        <view class="ai-fab-button {{fabMenuOpen ? 'open' : ''}}">
          <!-- 脉冲光环 -->
          <view class="fab-pulse-ring" wx:if="{{!fabMenuOpen}}"></view>
          <view class="fab-pulse-ring delay" wx:if="{{!fabMenuOpen}}"></view>
          <!-- 按钮内容 -->
          <text class="fab-icon">{{fabMenuOpen ? '✕' : '✨'}}</text>
        </view>
      </view>
    </movable-view>
  </movable-area>

  <!-- ==================== 新手引导遮罩 ==================== -->
  <view class="guide-overlay" wx:if="{{showGuide}}" catchtouchmove="preventTouchMove">
    <!-- 引导弹窗（居中显示） -->
    <view class="guide-tooltip animate-scale-in">
      <!-- 步骤图标 -->
      <view class="guide-icon">{{guideSteps[guideStep].icon}}</view>

      <!-- 步骤指示 -->
      <view class="guide-step-indicator">
        <text>{{guideStep + 1}} / {{guideSteps.length}}</text>
      </view>

      <text class="guide-title">{{guideSteps[guideStep].title}}</text>
      <text class="guide-desc">{{guideSteps[guideStep].desc}}</text>

      <!-- 指示点 -->
      <view class="guide-dots">
        <view
          class="guide-dot {{index === guideStep ? 'active' : ''}}"
          wx:for="{{guideSteps}}"
          wx:key="index"
        ></view>
      </view>

      <view class="guide-actions">
        <view class="guide-skip" bindtap="skipGuide">
          <text>跳过</text>
        </view>
        <view class="guide-next btn-ripple" bindtap="nextGuideStep">
          <text>{{guideStep === guideSteps.length - 1 ? '开始使用' : '下一步'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 庆祝撒花效果 ==================== -->
  <view class="confetti-container" wx:if="{{showConfetti}}">
    <view
      class="confetti-piece"
      wx:for="{{confettiPieces}}"
      wx:key="index"
      style="left: {{item.left}}%; background: {{item.color}}; animation-delay: {{item.delay}}s; animation-duration: {{item.duration}}s;"
    ></view>
  </view>

  <!-- ==================== 全局 Toast 提示 ==================== -->
  <view class="custom-toast {{toastShow ? 'show' : ''}} {{toastType}}" wx:if="{{toastShow}}">
    <text class="toast-icon">{{toastIcon}}</text>
    <text class="toast-text">{{toastText}}</text>
  </view>
</view>
