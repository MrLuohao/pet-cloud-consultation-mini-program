/**
 * ╔══════════════════════════════════════════════════════════════════════════════
 * ║  首页样式 | Home Page Styles                                                     ║
 * ║  Design: Modern • Fluid • Interactive                                            ║
 * ║  Inspired by: mstand.cn & Framer.com                                             ║
 * ╚══════════════════════════════════════════════════════════════════════════════
 */

/* ==================== 页面容器 ==================== */
.index-page {
  min-height: 100vh;
  background: var(--bg-secondary);
}

/* ==================== 主滚动区 ==================== */
.main-scroll {
  height: 100vh;
}

/* ==================== 搜索区域 ==================== */
.search-section {
  padding: var(--space-4) var(--space-6);
}

.search-bar {
  display: flex;
  align-items: center;
  height: 56rpx;
  padding: 0 var(--space-4);
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  border: 2px solid transparent;
  transition: all var(--duration-300) var(--ease-default);
}

.search-focused {
  background: var(--bg-elevated);
  border-color: var(--primary-300);
  box-shadow: 0 0 0 6rpx rgba(109, 50, 255, 0.1);
}

.search-icon {
  font-size: var(--font-lg);
  margin-right: var(--space-2);
  opacity: 0.5;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: var(--font-base);
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-tertiary);
}

.search-clear {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--neutral-300);
  border-radius: 50%;
  opacity: 0;
  transform: scale(0.5);
  transition: all var(--duration-200) var(--ease-default);
}

.search-clear.show {
  opacity: 1;
  transform: scale(1);
}

/* ==================== Hero Banner ==================== */
.hero-section {
  padding: var(--space-4) var(--space-6) var(--space-8);
}

.hero-card {
  position: relative;
  height: 360rpx;
  background: var(--neutral-900);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  transition: all var(--duration-500) var(--ease-default);
}

.hero-card.loaded {
  box-shadow: var(--shadow-xl), var(--shadow-glow-md);
}

.hero-card:active {
  transform: scale(0.98) rotateX(2deg);
}

/* Hero 背景 */
.hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(-45deg, #6D32FF, #A855F7, #EC4899, #3B82F6);
  background-size: 400% 400%;
}

/* 光点粒子 */
.hero-particles {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  animation: particleFloat 6s linear infinite;
}

.particle-1 {
  left: 10%;
  animation-delay: 0s;
}

.particle-2 {
  left: 30%;
  animation-delay: 1.5s;
}

.particle-3 {
  left: 60%;
  animation-delay: 3s;
}

.particle-4 {
  left: 80%;
  animation-delay: 4.5s;
}

@keyframes particleFloat {
  0% {
    transform: translateY(360rpx) scale(0);
    opacity: 0;
  }
  10% {
    opacity: 1;
    transform: translateY(300rpx) scale(1);
  }
  90% {
    opacity: 1;
    transform: translateY(60rpx) scale(1);
  }
  100% {
    transform: translateY(0) scale(0);
    opacity: 0;
  }
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  filter: blur(40px);
}

.hero-orb-1 {
  width: 200rpx;
  height: 200rpx;
  top: -40rpx;
  right: -40rpx;
  background: rgba(168, 133, 255, 0.3);
}

.hero-orb-2 {
  width: 160rpx;
  height: 160rpx;
  bottom: -30rpx;
  left: 20%;
  background: rgba(236, 72, 153, 0.25);
}

.hero-orb-3 {
  width: 120rpx;
  height: 120rpx;
  bottom: 40%;
  right: 10%;
  background: rgba(59, 130, 246, 0.2);
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
}

/* Hero 内容 */
.hero-content {
  position: relative;
  z-index: 2;
  padding: var(--space-8);
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-3);
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--radius-full);
  align-self: flex-start;
  margin-bottom: var(--space-4);
}

.tag-dot {
  width: 8px;
  height: 8px;
  background: #10B981;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

.hero-tag text {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.9);
  font-weight: var(--font-medium);
}

.hero-title {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  margin-bottom: var(--space-3);
}

.title-line {
  font-size: var(--font-4xl);
  font-weight: var(--font-bold);
  color: var(--text-inverse);
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.title-highlight {
  background: linear-gradient(135deg, #FFFFFF 0%, #F0EBFF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-desc {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
  margin-bottom: var(--space-6);
}

.hero-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-3) var(--space-8);
  background: var(--text-inverse);
  border-radius: var(--radius-full);
  overflow: hidden;
  align-self: flex-start;
}

.hero-btn text {
  position: relative;
  z-index: 2;
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--primary-600);
}

.btn-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% { left: -100%; }
  50%, 100% { left: 200%; }
}

/* 宠物装饰 */
.hero-pet {
  position: absolute;
  right: var(--space-6);
  bottom: var(--space-6);
  z-index: 3;
}

.pet-emoji {
  position: absolute;
  font-size: 80rpx;
  transition: all var(--duration-500) var(--ease-bounce);
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.1));
}

.pet-1 {
  font-size: 100rpx;
  right: 100rpx;
  bottom: 20rpx;
  animation: float 3s ease-in-out infinite;
}

.pet-2 {
  font-size: 70rpx;
  right: 10rpx;
  bottom: 60rpx;
  animation: float 2.5s ease-in-out infinite 0.5s;
}

.pet-3 {
  font-size: 60rpx;
  right: 160rpx;
  bottom: 0;
  animation: float 2s ease-in-out infinite 1s;
}

/* ==================== 快捷服务 ==================== */
.quick-section {
  padding: var(--space-6) var(--space-6);
}

.quick-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.section-title {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.section-more .arrow {
  transition: transform var(--duration-200) var(--ease-default);
}

.section-more:active .arrow {
  transform: translateX(4rpx);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
}

.quick-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-300) var(--ease-default);
}

.quick-card-hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

.quick-icon-wrapper {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.quick-purple {
  background: linear-gradient(135deg, var(--primary-100) 0%, var(--primary-200) 100%);
}

.quick-blue {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.quick-green {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.quick-orange {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.quick-icon {
  font-size: 32rpx;
  position: relative;
  z-index: 1;
}

.quick-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.8), transparent 70%);
}

.quick-name {
  font-size: var(--font-xs);
  font-weight: var(--font-medium);
  color: var(--text-secondary);
  text-align: center;
}

/* ==================== 数据展示 ==================== */
.stats-section {
  padding: 0 var(--space-6) var(--space-6);
}

.stats-card {
  display: flex;
  justify-content: space-around;
  padding: var(--space-6);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
}

.stat-value {
  font-size: var(--font-3xl);
  font-weight: var(--font-bold);
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* ==================== 推荐区域 ==================== */
.recommend-section {
  padding: var(--space-6) 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-6);
  margin-bottom: var(--space-4);
}

.section-tabs {
  display: flex;
  gap: var(--space-6);
}

.tab-item {
  position: relative;
  padding: var(--space-2) 0;
}

.tab-item text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  transition: color var(--duration-200) var(--ease-default);
}

.tab-item.active text {
  color: var(--text-primary);
  font-weight: var(--font-semibold);
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
}

.recommend-list {
  padding: 0 var(--space-6);
}

.recommend-card {
  display: flex;
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-300) var(--ease-default);
}

.recommend-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.recommend-cover {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  margin-right: var(--space-4);
  flex-shrink: 0;
  overflow: hidden;
}

.recommend-cover-0,
.recommend-purple {
  background: linear-gradient(135deg, var(--primary-200) 0%, var(--primary-300) 100%);
}

.recommend-cover-1,
.recommend-blue {
  background: linear-gradient(135deg, #BFDBFE 0%, #93C5FD 100%);
}

.recommend-cover-2,
.recommend-green {
  background: linear-gradient(135deg, #A7F3D0 0%, #6EE7B7 100%);
}

.recommend-cover-3,
.recommend-orange {
  background: linear-gradient(135deg, #FDE68A 0%, #FCD34D 100%);
}

.cover-emoji {
  font-size: 48rpx;
  position: relative;
  z-index: 1;
}

.cover-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.cover-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, transparent 100%);
}

.recommend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: var(--space-1) 0;
}

.recommend-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.meta-tag {
  padding: var(--space-1) var(--space-2);
  background: var(--primary-100);
  color: var(--primary-600);
  font-size: var(--font-xs);
  font-weight: var(--font-medium);
  border-radius: var(--radius-sm);
}

.meta-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.recommend-title {
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: var(--space-1);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.recommend-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.recommend-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.footer-stats {
  display: flex;
  gap: var(--space-4);
}

.stat-item {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.stat-item.liked {
  color: #ff4757;
}

/* ==================== 加载更多 ==================== */
.load-more {
  position: fixed;
  bottom: calc(50px + var(--safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-md);
  z-index: var(--z-sticky);
  transition: all var(--duration-300) var(--ease-default);
}

.load-more.loading {
  bottom: calc(70px + var(--safe-area-inset-bottom));
}

.load-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid var(--bg-tertiary);
  border-top-color: var(--primary-500);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.load-text {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* ==================== 动画增强 ==================== */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: slideUp 0.6s var(--ease-out) backwards;
}

/* ==================== 宠物档案卡模块 ==================== */
.pet-section {
  padding: var(--space-4) var(--space-6);
}

.pet-swiper {
  height: 220rpx;
  margin-top: var(--space-4);
}

.pet-card {
  position: relative;
  height: 200rpx;
  margin: 0 var(--space-2);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.pet-card-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(109, 50, 255, 0.05) 0%, rgba(168, 85, 247, 0.1) 100%);
}

.pet-card-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: var(--space-6);
  height: 100%;
}

.pet-avatar-wrapper {
  position: relative;
  margin-right: var(--space-5);
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--bg-tertiary);
}

.pet-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: var(--primary-100);
}

.pet-status-dot {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid var(--bg-elevated);
}

.pet-status-dot.status-healthy {
  background: var(--success);
}

.pet-status-dot.status-attention {
  background: var(--warning);
}

.pet-status-dot.status-unknown {
  background: var(--neutral-400);
}

.pet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.pet-name {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}

.pet-breed {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.pet-tags {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-1);
}

.pet-tag {
  padding: var(--space-1) var(--space-2);
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.pet-health-status {
  display: flex;
  align-items: center;
}

.health-indicator {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-full);
}

.health-indicator.healthy {
  background: var(--success-light);
}

.health-indicator.attention {
  background: var(--warning-light);
}

.health-indicator.unknown {
  background: var(--bg-tertiary);
}

.health-icon {
  font-size: var(--font-base);
}

.health-text {
  font-size: var(--font-xs);
  font-weight: var(--font-medium);
  color: var(--text-secondary);
}

/* 宠物空状态 */
.pet-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-8);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.pet-empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-3);
  opacity: 0.8;
}

.pet-empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  margin-bottom: var(--space-4);
}

.pet-empty-btn {
  padding: var(--space-2) var(--space-6);
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  color: var(--text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--font-medium);
}

.pet-empty-btn:active {
  transform: scale(0.95);
}

/* 骨架屏 */
.pet-skeleton {
  padding: 0 var(--space-2);
}

.skeleton-list {
  padding: 0 var(--space-6);
}

.skeleton-item {
  display: flex;
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
}

.skeleton-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  margin-right: var(--space-4);
  flex-shrink: 0;
}

.skeleton-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding: var(--space-2) 0;
}

/* ==================== 健康提醒模块 ==================== */
.reminder-section {
  padding: var(--space-4) var(--space-6);
}

.reminder-count {
  padding: var(--space-1) var(--space-3);
  background: var(--error-light);
  border-radius: var(--radius-full);
}

.reminder-count text {
  font-size: var(--font-xs);
  color: var(--error);
  font-weight: var(--font-medium);
}

.reminder-scroll {
  margin-top: var(--space-4);
  white-space: nowrap;
}

.reminder-list {
  display: inline-flex;
  gap: var(--space-3);
  padding-right: var(--space-6);
}

.reminder-card {
  display: inline-flex;
  align-items: center;
  width: 400rpx;
  padding: var(--space-4);
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  white-space: normal;
}

