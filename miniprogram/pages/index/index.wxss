}

.health-badge.unknown {
  background: var(--bg-tertiary);
}

.health-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.health-badge.healthy .health-dot {
  background: #10B981;
}

.health-badge.attention .health-dot {
  background: #F59E0B;
}

.health-badge.unknown .health-dot {
  background: var(--neutral-400);
}

.health-label {
  font-size: var(--font-xs);
  font-weight: var(--font-medium);
}

.health-badge.healthy .health-label {
  color: #10B981;
}

.health-badge.attention .health-label {
  color: #F59E0B;
}

.health-badge.unknown .health-label {
  color: var(--text-tertiary);
}

.pet-weight-badge {
  padding: var(--space-1) var(--space-2);
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
}

.pet-weight-badge text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

/* 新版空状态 */
.pet-empty-new {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-10) var(--space-8);
  background: var(--bg-elevated);
  border-radius: var(--radius-2xl);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.pet-empty-illustration {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: var(--space-5);
}

.empty-circle {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #F3E8FF 0%, #E9D5FF 100%);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

.empty-paw {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
}

.pet-empty-title {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.pet-empty-subtitle {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-bottom: var(--space-6);
}

.pet-empty-btn-new {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-full);
  box-shadow: 0 8rpx 24rpx rgba(109, 50, 255, 0.3);
  transition: all var(--duration-200) var(--ease-default);
}

.pet-empty-btn-new:active {
  transform: scale(0.95);
}

.btn-plus {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: #FFFFFF;
}

.pet-empty-btn-new text {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: #FFFFFF;
}

/* 今日任务模块样式 */
.task-section {
  padding: var(--space-4) var(--space-6);
}

.task-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}

.task-points {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-3);
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: var(--radius-full);
}

.task-points-icon {
  font-size: var(--font-base);
}

.task-points-value {
  font-size: var(--font-sm);
  font-weight: var(--font-bold);
  color: #B45309;
}

.task-progress-bar {
  height: 8rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  margin-bottom: var(--space-4);
  overflow: hidden;
}

.task-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-full);
  transition: width var(--duration-500) var(--ease-default);
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.task-card {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-200) var(--ease-default);
}

.task-card:active {
  transform: scale(0.98);
}

.task-card.completed {
  opacity: 0.7;
}

.task-icon-wrapper {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-tertiary);
  border-radius: var(--radius-lg);
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.task-icon-wrapper.completed {
  background: var(--success-light);
}

.task-icon {
  font-size: 28rpx;
}

.task-check {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 24rpx;
  height: 24rpx;
  background: var(--success);
  color: #FFFFFF;
  font-size: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-weight: bold;
}

.task-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.task-name {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.task-card.completed .task-name {
  text-decoration: line-through;
  color: var(--text-tertiary);
}

.task-desc {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.task-reward {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-1) var(--space-2);
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  border-radius: var(--radius-full);
}

.task-reward-icon {
  font-size: 20rpx;
}

.task-reward-value {
  font-size: var(--font-xs);
  font-weight: var(--font-bold);
  color: #B45309;
}

/* 安全区底部 */
.tabbar-safe {
  height: calc(100rpx + var(--safe-area-inset-bottom));
}
