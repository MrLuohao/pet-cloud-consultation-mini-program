/* index.wxss */
/* 重置样式 */
page {
  background-color: #0f0f30; /* 深蓝背景 */
  padding: 0;
  margin: 0;
}

.container {
  min-height: 100vh;
  padding: 40rpx 30rpx 0;
  display: flex;
  flex-direction: column;
  color: #fff;
  font-family: PingFang SC;
  position: relative;
}

/* 顶部导航栏样式 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 40rpx;
}

.header-left {
  display: flex;
  align-items: center;
}
.back-icon {
  width: 400rpx;
  height: 400rpx;
  margin-right: 20rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: bold;
  position: absolute;
  left: 50%;
  transform: translateX(-50%); /* 定位技巧：left:50% + transform:translateX(-50%) 实现水平居中 */
}

/* 搜索框样式 */
.search-box {
  position: relative;
  height: 80rpx;
  margin-bottom: 40rpx;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  top: 22rpx;
  width: 36rpx;
  height: 36rpx;
  z-index: 2;
}

.placeholder-style {
  color: rgba(255, 255, 255, 0.6); /* 半透明白色 */
}

.search-input {
  height: 100%;
  width: 100%;
  background-color: rgba(0, 0, 0, 0.2); /* 深蓝透明背景 */
  border: 2rpx solid #FF7BAC; /* 粉红色边框 */
  border-radius: 50rpx;
  padding: 0 80rpx;
  box-sizing: border-box;
  color: #fff;
  font-size: 28rpx;
}

/* 功能区标题样式 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.title-text {
  font-size: 32rpx;
  font-weight: bold;
}
.more-link {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 功能卡片区 */
.cards-container {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  margin-bottom: 40rpx;
}

.card {
  width: 160rpx;
  height: 200rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.2); /* 半透明深蓝背景 */
  border: 2rpx solid transparent;
  margin-bottom: 30rpx;
}

.card.health-card {
  border-color: #FF7BAC; /* 健康卡片有粉红边框 */
}

.card-icon {
  width: 70rpx;
  height: 70rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  padding: 0 10rpx;
}

/* 推荐区域 */
.recommend-container {
  margin-bottom: 30rpx;
}

.recommend-card {
  display: flex;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.recommend-image {
  width: 200rpx;
  height: 140rpx;
  border-radius: 15rpx;
  margin-right: 20rpx;
}

.recommend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recommend-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.recommend-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}