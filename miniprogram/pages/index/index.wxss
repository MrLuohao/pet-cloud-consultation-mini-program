/* ==================== 新版宠物卡片样式 - 堆叠卡片效果 ==================== */
.pet-stack-container {
  position: relative;
  margin-top: var(--space-4);
  padding: 0 var(--space-4);
}

.pet-stack {
  position: relative;
  height: 420rpx;
  perspective: 1000px;
}

/* 堆叠卡片基础样式 */
.pet-card-stack {
  position: absolute;
  left: 0;
  right: 0;
  height: 380rpx;
  background: var(--bg-elevated);
  border-radius: var(--radius-2xl);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  display: flex;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: center bottom;
  backface-visibility: hidden;
}

/* 卡片堆叠位置计算 */
.pet-card-stack {
  z-index: calc(10 - var(--card-index));
  transform: translateX(calc(var(--card-index) * 20rpx))
             translateY(calc(var(--card-index) * -15rpx))
             scale(calc(1 - abs(var(--card-index)) * 0.04));
  opacity: calc(1 - abs(var(--card-index)) * 0.15);
}

/* 当前激活的卡片 */
.pet-card-stack.active {
  z-index: 100;
  transform: translateX(0) translateY(0) scale(1);
  opacity: 1;
  box-shadow: 0 20rpx 60rpx rgba(109, 50, 255, 0.15);
}

/* 已滑过的卡片（左边） */
.pet-card-stack.prev {
  transform: translateX(-120%) translateY(0) scale(0.9);
  opacity: 0;
  pointer-events: none;
}

/* 未滑到的卡片（右边） */
.pet-card-stack.next {
  filter: brightness(0.95);
}

.pet-card-stack:active {
  box-shadow: 0 16rpx 48rpx rgba(109, 50, 255, 0.2);
}

/* ==================== 扇形展开效果 ==================== */

/* 扇形模式容器 */
.pet-stack.fan-mode {
  height: 520rpx;
  perspective: 1200px;
}

/* 扇形卡片核心几何 */
.pet-card-stack.fan-card {
  transform-origin: center bottom;
  transform: translateX(var(--fan-tx)) translateY(var(--fan-ty))
             rotate(var(--fan-angle)) scale(0.88);
  z-index: var(--fan-z) !important;
  opacity: 1 !important;
  pointer-events: auto !important;
  filter: none !important;
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.3s ease,
              z-index 0s;
}

/* 扇形模式下覆盖 prev/next 隐藏 */
.pet-card-stack.fan-card.prev,
.pet-card-stack.fan-card.next,
.pet-card-stack.fan-card.active {
  transform: translateX(var(--fan-tx)) translateY(var(--fan-ty))
             rotate(var(--fan-angle)) scale(0.88);
  opacity: 1;
  pointer-events: auto;
  filter: none;
}

/* 触摸悬浮效果 */
.pet-card-stack.fan-touched {
  transform: translateX(var(--fan-tx)) translateY(calc(var(--fan-ty) - 40rpx))
             rotate(var(--fan-angle)) scale(0.95) !important;
  z-index: 100 !important;
  box-shadow: 0 30rpx 80rpx rgba(109, 50, 255, 0.25);
}

/* 浮动视差动画 */
@keyframes fanFloat {
  0%, 100% { transform: translateX(var(--fan-tx)) translateY(var(--fan-ty))
                         rotate(var(--fan-angle)) scale(0.88); }
  50% { transform: translateX(var(--fan-tx)) translateY(calc(var(--fan-ty) - 8rpx))
                   rotate(var(--fan-angle)) scale(0.88); }
}

.pet-stack.fan-animating .pet-card-stack.fan-card {
  animation: fanFloat 3s ease-in-out infinite;
}

.pet-stack.fan-animating .pet-card-stack.fan-card:nth-child(1) {
  animation-delay: 0s;
}

.pet-stack.fan-animating .pet-card-stack.fan-card:nth-child(2) {
  animation-delay: 0.3s;
}

.pet-stack.fan-animating .pet-card-stack.fan-card:nth-child(3) {
  animation-delay: 0.6s;
}

.pet-stack.fan-animating .pet-card-stack.fan-card:nth-child(4) {
  animation-delay: 0.9s;
}

.pet-stack.fan-animating .pet-card-stack.fan-card:nth-child(5) {
  animation-delay: 1.2s;
}

/* 触摸时停止浮动动画 */
.pet-stack.fan-animating .pet-card-stack.fan-touched {
  animation: none;
}

/* 堆叠模式下 next 卡片微旋转暗示扇形 */
.pet-card-stack.next:nth-child(n+2) {
  transform: translateX(calc(var(--card-index) * 20rpx))
             translateY(calc(var(--card-index) * -15rpx))
             scale(calc(1 - abs(var(--card-index)) * 0.04))
             rotate(calc(var(--card-index) * 1.5deg));
}

