.page {
  min-height: 100vh;
  background: #1d1d1f;
}

.video-wrap {
  width: 100%;
  background: #000;
}

.video-player {
  width: 100%;
  height: 422rpx;
}

.no-video {
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #2c2c2e;
}

.no-video-icon {
  font-size: 80rpx;
}

.no-video-text {
  font-size: 28rpx;
  color: #86868b;
}

.info-card {
  background: #2c2c2e;
  margin: 16rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.chapter-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 24rpx;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #3c3c43;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #667eea;
  border-radius: 4rpx;
  transition: width 0.5s;
}

.progress-text {
  font-size: 24rpx;
  color: #667eea;
  width: 60rpx;
  text-align: right;
}
