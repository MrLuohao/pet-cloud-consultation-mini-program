.login-page {
  min-height: 100vh;
  background: #f8f8f8;
  padding: 0 32rpx 24rpx;
  box-sizing: border-box;
}

.login-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 144rpx 0 72rpx;
  box-sizing: border-box;
}

.login-card {
  width: 100%;
  border-radius: 60rpx;
  border: 2rpx solid rgba(238, 232, 251, 0.6);
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(16rpx);
  box-shadow: 0 20rpx 48rpx rgba(109, 50, 255, 0.06);
  padding: 44rpx 36rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  box-sizing: border-box;
}

.login-card__title {
  font-size: 44rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
}

.login-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.login-avatar {
  width: 176rpx;
  height: 176rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  position: relative;
}

.login-avatar::after {
  border: none;
}

.login-avatar__base {
  width: 176rpx;
  height: 176rpx;
  border-radius: 88rpx;
  border: 2rpx solid #e9dffa;
  background: linear-gradient(180deg, #fcfaff 0%, #f2ebff 100%);
  box-shadow: 0 16rpx 40rpx rgba(109, 50, 255, 0.08);
  overflow: hidden;
}

.login-avatar__image {
  width: 100%;
  height: 100%;
}

.login-avatar__edit {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  background: #7b52ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar__edit text {
  font-size: 26rpx;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
}

.login-avatar__tip,
.login-card__note,
.login-footer__text {
  font-size: 22rpx;
  color: #9b91b3;
}

.login-nickname {
  height: 104rpx;
  border-radius: 36rpx;
  border: 2rpx solid #e6dbf7;
  background: rgba(255, 255, 255, 0.78);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.login-nickname__input {
  width: 100%;
  font-size: 26rpx;
  color: #2b2438;
}

.login-nickname__placeholder {
  color: #a197b3;
}

.login-submit {
  width: 100%;
  height: 108rpx;
  border-radius: 54rpx;
  border: none;
  background: linear-gradient(180deg, #7c55ff 0%, #6d32ff 100%);
  box-shadow: 0 20rpx 48rpx rgba(109, 50, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-submit::after {
  border: none;
}

.login-submit text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 700;
}

.login-submit--loading {
  opacity: 0.78;
}

.login-card__note {
  text-align: center;
}

.login-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding-bottom: 8rpx;
}

.login-footer__link {
  font-size: 22rpx;
  color: #7b52ff;
  font-weight: 600;
}
