/* pages/login/login.wxss */
.login-container {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #FFFFFF;
}

.login-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80%;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.95);
  position: relative;
  z-index: 1;
}

.login-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.login-tip {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
  margin-bottom: 10rpx;
}

.login-subtip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 34rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}