/* pages/login/login.wxss - Apple 风格登录页样式 */

.page {
  min-height: 100vh;
  background: #FFFFFF;
}

/* ==================== 跳过按钮 ==================== */
.skip-btn {
  position: absolute;
  top: 100rpx;
  right: 40rpx;
  z-index: 100;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 32rpx;
}

.skip-btn:active {
  background: rgba(0, 0, 0, 0.1);
}

/* ==================== 登录容器 ==================== */
.login-container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 80rpx 48rpx;
  overflow: hidden;
}

/* ==================== Logo 区域 ==================== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
  margin-bottom: 80rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.3);
}

.logo-emoji {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #86868B;
}

/* ==================== 登录区域 ==================== */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #86868B;
  margin-bottom: 48rpx;
}

/* ==================== 用户信息输入区域 ==================== */
.user-info-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 48rpx;
}

.avatar-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  overflow: visible;
}

.avatar-btn::after {
  border: none;
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  background: #f5f5f5;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #f0f0f0;
}

.avatar-emoji {
  font-size: 64rpx;
}

.avatar-edit-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.avatar-tip {
  font-size: 24rpx;
  color: #86868B;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.nickname-input-wrap {
  width: 100%;
  background: #F5F5F7;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  color: #1D1D1F;
  text-align: center;
}

.nickname-input::placeholder {
  color: #A1A1A6;
}

/* ==================== 登录按钮 ==================== */
.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s ease;
}

.login-btn::after {
  border: none;
}

.login-btn-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.login-btn.loading {
  opacity: 0.7;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 32rpx;
}

/* ==================== 用户协议 ==================== */
.agreement {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  padding: 0 32rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #A1A1A6;
}

.agreement-link {
  font-size: 24rpx;
  color: #667eea;
}

/* ==================== 底部装饰 ==================== */
.bottom-decoration {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  pointer-events: none;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.05) 100%);
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  bottom: -100rpx;
  right: -80rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: 40rpx;
  left: -60rpx;
}

.circle-3 {
  width: 120rpx;
  height: 120rpx;
  bottom: 200rpx;
  right: 60rpx;
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.fade-in {
  animation: fadeIn 0.6s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.slide-up {
  animation: slideUp 0.6s ease 0.2s backwards;
}
