<view class="login-page">
  <view class="login-shell">
    <view class="login-card">
      <text class="login-card__title">欢迎登录伴宠云诊</text>

      <view class="login-profile">
        <button class="login-avatar" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <view class="login-avatar__base">
            <image wx:if="{{avatarUrl}}" class="login-avatar__image" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError"></image>
          </view>
          <view class="login-avatar__edit">
            <text>＋</text>
          </view>
        </button>
        <text class="login-avatar__tip">点击头像设置资料</text>
      </view>

      <view class="login-nickname">
        <input
          type="nickname"
          class="login-nickname__input"
          placeholder="填写昵称"
          placeholder-class="login-nickname__placeholder"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          bindblur="onNicknameBlur"
        />
      </view>

      <button
        class="login-submit {{isLoading ? 'login-submit--loading' : ''}}"
        bindtap="handleLogin"
        disabled="{{isLoading || isUploadingAvatar}}"
      >
        <text>{{isUploadingAvatar ? '头像上传中...' : (isLoading ? '登录中...' : '微信一键登录')}}</text>
      </button>

      <text class="login-card__note">微信授权后即可继续</text>
    </view>

    <view class="login-footer">
      <text class="login-footer__text">登录即表示同意</text>
      <text class="login-footer__link">《用户协议》与《隐私政策》</text>
    </view>
  </view>
</view>
