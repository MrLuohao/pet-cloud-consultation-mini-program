<!--pages/chat/chat.wxml-->
<view class="page">
  <!-- 聊天内容区 -->
  <scroll-view
    class="chat-container"
    scroll-y
    scroll-into-view="{{toView}}"
    scroll-with-animation
    bindscrolltoupper="onScrollToUpper"
    bindscrolltolower="onScrollToLower"
  >
    <view class="chat-list">
      <!-- 顶部锚点 -->
      <view id="chat-top"></view>

      <!-- 欢迎消息 -->
      <view class="chat-item chat-item-ai" wx:if="{{messages.length === 0}}">
        <view class="chat-avatar">
          <text class="avatar-icon">🤖</text>
        </view>
        <view class="chat-content">
          <view class="message-bubble">
            <text class="message-text">您好！我是伴宠云诊的AI智能助手。我可以帮您：</text>
          </view>
          <view class="message-bubble">
            <text class="message-text">• 回答宠物健康问题</text>
          </view>
          <view class="message-bubble">
            <text class="message-text">• 提供养宠建议和知识</text>
          </view>
          <view class="message-bubble">
            <text class="message-text">• AI健康初步诊断</text>
          </view>
          <view class="quick-actions">
            <view class="quick-btn" bindtap="sendQuickMessage" data-message="狗狗食欲不振怎么办？">
              <text>🐕 狗狗食欲不振</text>
            </view>
            <view class="quick-btn" bindtap="sendQuickMessage" data-message="猫咪掉毛严重怎么办？">
              <text>🐱 猫咪掉毛问题</text>
            </view>
            <view class="quick-btn" bindtap="goToDiagnosis">
              <text>🏥 AI健康诊断</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 聊天消息列表 -->
      <block wx:for="{{messages}}" wx:key="id">
        <!-- AI消息 -->
        <view id="msg-{{item.id}}" class="chat-item chat-item-ai" wx:if="{{item.role === 'ai'}}">
          <view class="chat-avatar">
            <text class="avatar-icon">🤖</text>
          </view>
          <view class="chat-content">
            <view class="message-bubble ai-bubble">
              <!-- 使用解析后的结构化内容 -->
              <view class="markdown-content" wx:if="{{item.parsedContent && item.parsedContent.length > 0}}">
                <block wx:for="{{item.parsedContent}}" wx:for-item="block" wx:key="index">
                  <!-- 标题 -->
                  <view class="md-heading md-heading-{{block.level}}" wx:if="{{block.type === 'heading'}}">
                    <block wx:for="{{block.content}}" wx:for-item="seg" wx:key="idx">
                      <text class="{{seg.type === 'bold' ? 'md-bold' : ''}}">{{seg.content}}</text>
                    </block>
                  </view>

                  <!-- 段落 -->
                  <view class="md-paragraph" wx:if="{{block.type === 'paragraph'}}">
                    <block wx:for="{{block.content}}" wx:for-item="seg" wx:key="idx">
                      <text class="{{seg.type === 'bold' ? 'md-bold' : ''}}">{{seg.content}}</text>
                    </block>
                  </view>

                  <!-- 列表项 -->
                  <view class="md-list-item" wx:if="{{block.type === 'listItem'}}">
                    <view class="md-list-marker">
                      <text wx:if="{{block.ordered}}">{{block.number}}</text>
                      <text wx:else class="md-bullet">•</text>
                    </view>
                    <view class="md-list-content">
                      <block wx:for="{{block.content}}" wx:for-item="seg" wx:key="idx">
                        <text class="{{seg.type === 'bold' ? 'md-bold' : ''}}">{{seg.content}}</text>
                      </block>
                    </view>
                  </view>
                </block>
              </view>
              <!-- 降级显示原始内容 -->
              <text class="message-text" wx:else>{{item.content}}</text>
            </view>
            <view class="message-time" wx:if="{{item.time}}">{{item.time}}</view>
          </view>
        </view>

        <!-- 用户消息 -->
        <view id="msg-{{item.id}}" class="chat-item chat-item-user" wx:if="{{item.role === 'user'}}">
          <view class="chat-content">
            <view class="message-bubble message-bubble-user">
              <text class="message-text">{{item.content}}</text>
            </view>
            <view class="message-time" wx:if="{{item.time}}">{{item.time}}</view>
          </view>
          <view class="chat-avatar">
            <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
            <view wx:else class="avatar-placeholder">{{userInfo.nickname ? userInfo.nickname[0] : '用'}}</view>
          </view>
        </view>
      </block>

      <!-- 加载中 -->
      <view class="chat-item chat-item-ai" wx:if="{{isLoading}}">
        <view class="chat-avatar">
          <text class="avatar-icon">🤖</text>
        </view>
        <view class="chat-content">
          <view class="message-bubble">
            <view class="typing-indicator">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部锚点 -->
      <view id="chat-bottom"></view>
    </view>
  </scroll-view>

  <!-- 快捷滚动按钮 -->
  <view class="scroll-actions" wx:if="{{messages.length > 5}}">
    <view class="scroll-btn scroll-to-top" bindtap="scrollToTop">
      <text>↑</text>
    </view>
    <view class="scroll-btn scroll-to-bottom" bindtap="scrollToBottom">
      <text>↓</text>
    </view>
  </view>

  <!-- 模型选择器 -->
  <view class="model-selector">
    <view class="model-item {{modelType === 'qwen' ? 'active' : ''}}" bindtap="selectModel" data-model="qwen">
      <text class="model-name">Qwen Max</text>
    </view>
    <view class="model-item {{modelType === 'deepseek' ? 'active' : ''}}" bindtap="selectModel" data-model="deepseek">
      <text class="model-name">DeepSeek</text>
    </view>
  </view>

  <!-- 输入区 -->
  <view class="input-container">
    <view class="input-wrapper">
      <textarea
        class="input-area"
        placeholder="请输入您的问题..."
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        adjust-position="{{true}}"
        show-confirm-bar="{{false}}"
        maxlength="500"
        auto-height
      />
      <view class="input-actions">
        <button class="send-btn {{inputText ? 'active' : ''}}" bindtap="sendMessage" disabled="{{!inputText || isLoading}}">
          <text class="send-icon">{{isLoading ? '···' : '发送'}}</text>
        </button>
      </view>
    </view>
  </view>
</view>
