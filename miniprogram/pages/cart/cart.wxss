/*
  ╔══════════════════════════════════════════════════════════════════════════════
  ║  购物车页面样式 | Cart Page Styles
  ║  Design: 与首页保持一致的紫色主题
  ╚══════════════════════════════════════════════════════════════════════════════
*/

/* ==================== 页面容器 ==================== */
.cart-page {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ==================== 顶部导航栏 ==================== */
.cart-header {
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-6) var(--space-6);
  background: var(--bg-elevated);
  border-bottom: 1rpx solid var(--border-subtle);
}

.header-left {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.header-title {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.cart-count-badge {
  background: var(--gradient-primary);
  color: var(--text-inverse);
  font-size: var(--font-xs);
  font-weight: var(--font-semibold);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  min-width: 36rpx;
  text-align: center;
}

.header-actions {
  display: flex;
  gap: var(--space-4);
}

.action-btn {
  padding: var(--space-3) var(--space-5);
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  transition: all var(--duration-200) var(--ease-default);
}

.action-btn.primary {
  background: var(--primary-100);
  color: var(--primary-600);
  font-weight: var(--font-medium);
}

.action-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* ==================== 空购物车 ==================== */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  min-height: 70vh;
}

.empty-illustration {
  position: relative;
  width: 280rpx;
  height: 240rpx;
  margin-bottom: var(--space-12);
}

.empty-cart-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-body {
  font-size: 140rpx;
  animation: cartBounce 2s ease-in-out infinite;
}

@keyframes cartBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.empty-sparkles {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
}

.sparkle {
  position: absolute;
  font-size: 32rpx;
  animation: sparkle 1.5s ease-in-out infinite;
}

.sparkle.s1 {
  top: 0;
  right: 20rpx;
  animation-delay: 0s;
}

.sparkle.s2 {
  top: 40rpx;
  left: 20rpx;
  animation-delay: 0.5s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1); }
}

.empty-pet {
  position: absolute;
  bottom: 0;
  right: 20rpx;
  font-size: 60rpx;
  animation: petPeek 3s ease-in-out infinite;
}

@keyframes petPeek {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(-10rpx) rotate(-5deg); }
  75% { transform: translateX(10rpx) rotate(5deg); }
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  margin-bottom: var(--space-4);
}

.empty-desc {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  margin-bottom: var(--space-12);
}

.empty-actions {
  display: flex;
  gap: var(--space-6);
}

.goto-shop-btn {
  background: var(--gradient-primary);
  color: var(--text-inverse);
  padding: var(--space-6) var(--space-12);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  box-shadow: var(--shadow-glow-sm);
}

.goto-shop-btn::after {
  border: none;
}

.goto-collect-btn {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  padding: var(--space-6) var(--space-10);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: var(--font-medium);
  border: 2rpx solid var(--border-default);
}

.goto-collect-btn::after {
  border: none;
}

/* ==================== 购物车内容区 ==================== */
.cart-content {
  height: calc(100vh - 120rpx);
}

/* ==================== 满减凑单提示条 ==================== */
.promo-banner {
  display: flex;
  align-items: center;
  margin: var(--space-6) var(--space-6) 0;
  padding: var(--space-5) var(--space-6);
  background: linear-gradient(135deg, var(--primary-50) 0%, var(--primary-100) 100%);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(109, 50, 255, 0.15);
}

.promo-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-5);
  flex-shrink: 0;
}

.promo-icon {
  font-size: var(--font-base);
}

.promo-content {
  flex: 1;
  min-width: 0;
}

.promo-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.promo-highlight {
  color: var(--primary-600);
  font-weight: var(--font-semibold);
}

.promo-link {
  color: var(--primary-600);
  font-weight: var(--font-medium);
}

.promo-progress {
  margin-top: var(--space-2);
}

.progress-bar {
  height: 8rpx;
  background: rgba(109, 50, 255, 0.15);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  transition: width var(--duration-500) var(--ease-default);
}

.promo-arrow {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  margin-left: var(--space-3);
}

/* ==================== 限时优惠提醒 ==================== */
.flash-reminder {
  display: flex;
  align-items: center;
  margin: var(--space-4) var(--space-6) 0;
  padding: var(--space-4) var(--space-6);
  background: linear-gradient(135deg, var(--warning-light) 0%, #FFF3CD 100%);
  border-radius: var(--radius-md);
}

.flash-icon {
  font-size: var(--font-base);
  margin-right: var(--space-3);
}

.flash-text {
  flex: 1;
  font-size: var(--font-sm);
  color: #B8860B;
}

.flash-countdown {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.countdown-label {
  font-size: var(--font-xs);
  color: #B8860B;
}

.countdown-time {
  background: #B8860B;
  color: var(--text-inverse);
  font-size: var(--font-xs);
  font-weight: var(--font-semibold);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-sm);
  font-family: 'SF Mono', monospace;
}

/* ==================== 店铺分组 ==================== */
.cart-section {
  padding: var(--space-6) 0;
}

.shop-group {
  margin: 0 var(--space-6) var(--space-6);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.shop-header {
  display: flex;
  align-items: center;
  padding: var(--space-6);
  border-bottom: 1rpx solid var(--border-subtle);
}

.shop-select {
  margin-right: var(--space-4);
}

.shop-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.shop-badge {
  background: var(--gradient-primary);
  color: var(--text-inverse);
  font-size: var(--font-xs);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-xs);
  font-weight: var(--font-medium);
}

.shop-name {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.shop-arrow {
  font-size: var(--font-base);
  color: var(--text-tertiary);
}

.shop-service {
  display: flex;
  gap: var(--space-2);
}

.service-tag {
  font-size: var(--font-xs);
  color: var(--success);
  background: var(--success-light);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-xs);
}

/* 店铺优惠券 */
.shop-coupon-bar {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-6);
  background: linear-gradient(90deg, var(--warning-light) 0%, var(--primary-50) 100%);
  border-bottom: 1rpx solid var(--border-subtle);
}

.coupon-icon {
  font-size: var(--font-sm);
  margin-right: var(--space-2);
}

.coupon-text {
  flex: 1;
  font-size: var(--font-sm);
  color: #B8860B;
}

.coupon-action {
  font-size: var(--font-sm);
  color: var(--primary-600);
  font-weight: var(--font-medium);
}

/* 店铺小计 */
.shop-subtotal {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: var(--space-5) var(--space-6);
  background: var(--bg-tertiary);
  gap: var(--space-3);
}

.subtotal-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.subtotal-divider {
  color: var(--border-default);
}

.subtotal-price {
  font-size: var(--font-base);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

/* ==================== 商品列表 ==================== */
.product-list {
  padding: 0;
}

.product-card {
  position: relative;
  display: flex;
  padding: var(--space-6);
  border-bottom: 1rpx solid var(--border-subtle);
  transition: all var(--duration-300) var(--ease-default);
}

.product-card:last-child {
  border-bottom: none;
}

.product-card.selected {
  background: linear-gradient(135deg, var(--primary-50) 0%, #F8F5FF 100%);
}

.product-card.flash-sale {
  background: linear-gradient(135deg, #FFFBF0 0%, #FFF6E0 100%);
}

/* 限时优惠角标 */
.flash-badge {
  position: absolute;
  top: var(--space-4);
  right: var(--space-4);
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: var(--text-inverse);
  font-size: var(--font-xs);
  font-weight: var(--font-semibold);
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-sm);
  z-index: 5;
}

/* 降价标识 */
.price-drop-badge {
  position: absolute;
  top: var(--space-4);
  left: 80rpx;
  background: var(--error);
  color: var(--text-inverse);
  font-size: 18rpx;
  font-weight: var(--font-semibold);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-xs);
  z-index: 5;
}

/* 选择框 */
.product-checkbox {
  display: flex;
  align-items: flex-start;
  padding-top: var(--space-1);
  margin-right: var(--space-4);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid var(--neutral-300);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-200) var(--ease-default);
  background: var(--bg-elevated);
}

.checkbox.checked {
  background: var(--gradient-primary);
  border-color: transparent;
}

.checkbox text {
  color: var(--text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--font-bold);
}

/* 商品图片 */
.product-image-wrapper {
  position: relative;
  margin-right: var(--space-5);
  flex-shrink: 0;
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  background: var(--bg-tertiary);
}

.image-badge {
  position: absolute;
  top: 0;
  left: 0;
  padding: var(--space-2) var(--space-3);
  font-size: var(--font-xs);
  font-weight: var(--font-semibold);
  color: var(--text-inverse);
  border-radius: var(--radius-md) 0 var(--radius-sm) 0;
}

.image-badge.hot {
  background: linear-gradient(135deg, var(--error) 0%, #FF4757 100%);
}

.image-badge.new {
  background: linear-gradient(135deg, var(--success) 0%, #00CEC9 100%);
}

.image-badge.sale {
  background: var(--gradient-primary);
}

.stock-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: var(--text-inverse);
  font-size: var(--font-xs);
  text-align: center;
  padding: var(--space-2) 0;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
}

/* 商品信息 */
.product-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.product-title-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
}

.product-labels {
  display: flex;
  gap: var(--space-2);
  flex-shrink: 0;
  flex-wrap: wrap;
}

.label-tag {
  font-size: 18rpx;
  font-weight: var(--font-semibold);
  padding: var(--space-1) var(--space-2);
  border-radius: var(--radius-xs);
}

.label-tag.category {
  background: var(--primary-100);
  color: var(--primary-600);
}

.label-tag.hot {
  background: var(--error-light);
  color: var(--error);
}

.label-tag.new {
  background: var(--success-light);
  color: var(--success);
}

.label-tag.sale {
  background: var(--primary-100);
  color: var(--primary-600);
}

.product-name {
  font-size: var(--font-base);
  font-weight: var(--font-medium);
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 规格选择 */
.spec-selector {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  max-width: fit-content;
}

.spec-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.spec-arrow {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* 服务标签 */
.service-tags {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.service-item {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.service-item::before {
  content: "✓";
  margin-right: var(--space-1);
  color: var(--success);
}

/* 销量评分 */
.product-meta {
  display: flex;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.meta-item.rating .rating-star {
  color: #FFD700;
}

.meta-item.rating .rating-value {
  color: var(--text-secondary);
  font-weight: var(--font-medium);
}

/* 价格和数量行 */
.price-qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-2);
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: var(--font-sm);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

.price-integer {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--primary-600);
  font-family: 'DIN Alternate', -apple-system, sans-serif;
}

.price-decimal {
  font-size: var(--font-sm);
  font-weight: var(--font-semibold);
  color: var(--primary-600);
}

.original-price {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  text-decoration: line-through;
  margin-left: var(--space-3);
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  color: var(--text-secondary);
  background: var(--bg-elevated);
  transition: all var(--duration-200) var(--ease-default);
}

.qty-btn:active {
  background: var(--bg-tertiary);
}

.qty-btn.disabled {
  color: var(--text-tertiary);
  opacity: 0.5;
}

.qty-input {
  width: 72rpx;
  height: 56rpx;
  text-align: center;
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  background: var(--bg-elevated);
  border: none;
}

/* 优惠标签 */
.promo-tags {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
  margin-top: var(--space-2);
}

.promo-tag {
  font-size: var(--font-xs);
  color: var(--primary-600);
  background: var(--primary-50);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-xs);
  border: 1rpx solid rgba(109, 50, 255, 0.2);
}

/* 快捷操作区 */
.quick-actions {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: flex-end;
  gap: 0;
  padding: var(--space-4) var(--space-6);
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.95) 30%);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all var(--duration-300) var(--ease-default);
  pointer-events: none;
}

.quick-actions.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-3) var(--space-6);
}

.action-icon {
  font-size: var(--font-lg);
}

.action-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.action-item.delete .action-icon,
.action-item.delete .action-text {
  color: var(--error);
}

/* ==================== 失效商品区域 ==================== */
.invalid-section {
  margin: 0 var(--space-6) var(--space-6);
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.invalid-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5) var(--space-6);
  background: var(--bg-tertiary);
}

.invalid-title {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.invalid-clear {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.invalid-list {
  padding: var(--space-4) var(--space-6);
}

.invalid-item {
  display: flex;
  align-items: center;
  padding: var(--space-4) 0;
  opacity: 0.6;
}

.invalid-image {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: var(--space-5);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.invalid-image image {
  width: 100%;
  height: 100%;
  filter: grayscale(100%);
}

.invalid-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: var(--font-xs);
}

.invalid-info {
  flex: 1;
  min-width: 0;
}

.invalid-name {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.invalid-spec {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-2);
}

.find-similar-btn {
  padding: var(--space-3) var(--space-6);
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* ==================== 推荐区域 ==================== */
.recommend-section {
  margin: var(--space-6) 0;
  padding: var(--space-6) 0;
  background: var(--bg-elevated);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--space-6) var(--space-5);
}

.section-title {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.title-icon {
  font-size: var(--font-base);
}

.title-text {
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}

.section-more {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.recommend-scroll {
  width: 100%;
}

.recommend-list {
  display: flex;
  gap: var(--space-4);
  padding: 0 var(--space-6);
}

.recommend-card {
  position: relative;
  width: 280rpx;
  flex-shrink: 0;
  background: var(--bg-tertiary);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.recommend-image-wrap {
  position: relative;
  width: 100%;
  height: 220rpx;
}

.recommend-image {
  width: 100%;
  height: 100%;
}

.recommend-badge {
  position: absolute;
  top: var(--space-2);
  left: var(--space-2);
  background: var(--gradient-primary);
  color: var(--text-inverse);
  font-size: 18rpx;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-xs);
}

.recommend-info {
  padding: var(--space-4);
}

.recommend-name {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  height: 64rpx;
}

.recommend-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: var(--space-3);
  padding-right: 56rpx;
}

.recommend-price {
  font-size: var(--font-base);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

.recommend-sales {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.add-cart-btn {
  position: absolute;
  bottom: var(--space-4);
  right: var(--space-4);
  width: 48rpx;
  height: 48rpx;
  background: var(--gradient-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: var(--font-light);
  box-shadow: var(--shadow-glow-sm);
}

/* ==================== 底部安全区 ==================== */
.bottom-safe-area {
  height: 60rpx;
}

/* ==================== 底部结算栏 ==================== */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-elevated);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: var(--z-fixed);
}

.coupon-entry {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-6);
  background: linear-gradient(90deg, var(--warning-light) 0%, var(--primary-50) 100%);
  border-bottom: 1rpx solid var(--border-subtle);
}

.coupon-entry-icon {
  font-size: var(--font-sm);
  margin-right: var(--space-2);
}

.coupon-entry-text {
  flex: 1;
  font-size: var(--font-sm);
  color: #B8860B;
}

.coupon-entry-arrow {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.coupon-entry-text.coupon-selected {
  color: var(--primary-600);
  font-weight: 500;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-entry-text.no-coupon {
  color: var(--text-tertiary);
}

.coupon-discount {
  color: #ff6b6b;
  font-size: var(--font-sm);
  font-weight: 600;
  margin-left: var(--space-2);
}

.coupon-entry-clear {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: var(--space-3);
}

.checkout-main {
  display: flex;
  align-items: center;
  padding: var(--space-4) var(--space-6);
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
}

.select-all-wrap {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding-right: var(--space-5);
  flex-shrink: 0;
}

.select-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.checkout-price-area {
  flex: 1;
  min-width: 0;
  padding: 0 var(--space-4);
}

.price-detail-row {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.total-price-wrap {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: var(--font-sm);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

.total-price {
  font-size: var(--font-2xl);
  font-weight: var(--font-bold);
  color: var(--primary-600);
  font-family: 'DIN Alternate', -apple-system, sans-serif;
}

.price-extra-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-top: var(--space-1);
}

.shipping-info {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

.save-info {
  font-size: var(--font-xs);
  color: var(--success);
  background: var(--success-light);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
}

.checkout-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--gradient-primary);
  min-width: 200rpx;
  height: 88rpx;
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-glow-sm);
  flex-shrink: 0;
  transition: all var(--duration-200) var(--ease-default);
}

.checkout-btn:active {
  transform: scale(0.96);
}

.checkout-btn-text {
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
}

.checkout-btn-sub {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: var(--space-1);
}

.checkout-btn.disabled {
  background: var(--neutral-300);
  box-shadow: none;
}

/* ==================== 规格选择弹窗 ==================== */
.spec-popup {
  position: fixed;
  inset: 0;
  background: var(--bg-overlay);
  z-index: var(--z-modal);
  opacity: 0;
  visibility: hidden;
  transition: all var(--duration-300) var(--ease-default);
}

.spec-popup.show {
  opacity: 1;
  visibility: visible;
}

.spec-popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-elevated);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform var(--duration-300) var(--ease-default);
}

.spec-popup.show .spec-popup-content {
  transform: translateY(0);
}

.spec-popup-header {
  display: flex;
  padding: var(--space-6);
  border-bottom: 1rpx solid var(--border-subtle);
}

.spec-product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  margin-right: var(--space-5);
}

.spec-product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-2);
}

.spec-product-price {
  font-size: var(--font-xl);
  font-weight: var(--font-bold);
  color: var(--primary-600);
}

.spec-product-stock {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.spec-selected {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.spec-close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-2xl);
  color: var(--text-tertiary);
}

.spec-popup-body {
  max-height: 50vh;
  padding: var(--space-6);
}

.spec-group {
  margin-bottom: var(--space-8);
}

.spec-group-name {
  font-size: var(--font-base);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
  margin-bottom: var(--space-4);
  display: block;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
}

.spec-option {
  padding: var(--space-4) var(--space-8);
  background: var(--bg-tertiary);
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  font-size: var(--font-sm);
  color: var(--text-primary);
  transition: all var(--duration-200) var(--ease-default);
}

.spec-option.selected {
  background: var(--primary-50);
  border-color: var(--primary-500);
  color: var(--primary-600);
}

.spec-option.disabled {
  opacity: 0.4;
  text-decoration: line-through;
}

.spec-popup-footer {
  padding: var(--space-6);
  padding-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-subtle);
}

.spec-confirm-btn {
  width: 100%;
  height: 88rpx;
  background: var(--gradient-primary);
  color: var(--text-inverse);
  font-size: var(--font-lg);
  font-weight: var(--font-semibold);
  border-radius: var(--radius-2xl);
  display: flex;
  align-items: center;
  justify-content: center;
}

.spec-confirm-btn::after {
  border: none;
}
