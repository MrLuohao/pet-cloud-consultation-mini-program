/* pages/pet/list.wxss */
.pet-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx 30rpx calc(140rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 30rpx calc(140rpx + env(safe-area-inset-bottom));
}

/* 宠物列表 */
.pet-list {
  margin-bottom: 20rpx;
}

.pet-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.pet-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 25rpx;
}

.pet-info {
  flex: 1;
}

.pet-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.pet-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-right: 15rpx;
}

.pet-gender {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.pet-breed {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.pet-extra {
  font-size: 24rpx;
  color: #999;
}

.pet-extra text {
  margin-right: 20rpx;
}

.health-status {
  color: #4caf50;
}

/* 空状态 */
.empty-state {
  padding-top: 200rpx;
  text-align: center;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: calc(30rpx + constant(safe-area-inset-bottom));
  bottom: calc(30rpx + env(safe-area-inset-bottom));
  left: 30rpx;
  right: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 30rpx;
  border-radius: 50rpx;
  text-align: center;
  font-size: 30rpx;
}
