<!--pages/order/review.wxml-->
<view class="review-container">
  <!-- 商品信息 -->
  <view class="product-card" wx:if="{{orderItem}}">
    <image class="product-cover" src="{{orderItem.coverUrl}}" mode="aspectFill" />
    <view class="product-info">
      <text class="product-name">{{orderItem.productName}}</text>
      <view class="product-meta">
        <text class="product-price">¥{{orderItem.price}}</text>
        <text class="product-quantity">x{{orderItem.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 评分 -->
  <view class="rating-card">
    <text class="card-title">评分</text>
    <view class="rating-stars">
      <text
        wx:for="{{[1,2,3,4,5]}}"
        wx:key="*this"
        class="star {{rating >= item ? 'active' : ''}}"
        data-rating="{{item}}"
        bindtap="setRating"
      >★</text>
    </view>
    <text class="rating-text">{{rating === 5 ? '非常好' : rating === 4 ? '很好' : rating === 3 ? '一般' : rating === 2 ? '较差' : '非常差'}}</text>
  </view>

  <!-- 评价内容 -->
  <view class="content-card">
    <textarea
      class="review-textarea"
      placeholder="分享您的购买体验，帮助其他用户做出选择~"
      placeholder-class="textarea-placeholder"
      maxlength="500"
      value="{{content}}"
      bindinput="onContentInput"
    />
    <text class="char-count">{{content.length}}/500</text>
  </view>

  <!-- 图片上传 -->
  <view class="image-card">
    <text class="card-title">上传图片（可选，最多{{maxImages}}张）</text>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
        <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">✕</view>
      </view>
      <view class="add-image-btn" wx:if="{{images.length < maxImages}}" bindtap="chooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitReview" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交评价'}}
    </button>
  </view>
</view>
