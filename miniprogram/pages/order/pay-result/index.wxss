/* pages/order/pay-result/index.wxss */
.result-page {
  min-height: 100vh;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 40rpx;
}

.result-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 32rpx;
}

.result-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}
.success-wrap { background: rgba(52,199,89,0.12); }
.fail-wrap    { background: rgba(255,59,48,0.12); }

.result-icon { font-size: 56rpx; font-weight: 700; }
.success-icon { color: #34c759; }
.fail-icon    { color: #ff3b30; }

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

.result-amount {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}
.amount-label { font-size: 26rpx; color: #86868b; }
.amount-value { font-size: 52rpx; font-weight: 700; color: #1d1d1f; }

.order-summary {
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  text-align: left;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.summary-row:last-child { border-bottom: none; }
.summary-label { font-size: 26rpx; color: #86868b; flex-shrink: 0; }
.summary-value { font-size: 26rpx; color: #1d1d1f; text-align: right; flex: 1; margin-left: 16rpx; }
.order-no { color: #007aff; font-size: 24rpx; }

.summary-loading { padding: 20rpx 0; }
.loading-text { font-size: 26rpx; color: #aeaeb2; }

.result-tip { font-size: 26rpx; color: #86868b; line-height: 1.6; }

.fail-tips {
  margin-top: 24rpx;
  text-align: left;
  background: #fff8f7;
  border-radius: 12rpx;
  padding: 20rpx;
}
.fail-tip-item {
  display: block;
  font-size: 24rpx;
  color: #ff3b30;
  line-height: 2;
}

.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 0;
}
.btn-primary::after { border: none; }
.btn-secondary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #f0f0f5;
  color: #1d1d1f;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 0;
}
.btn-secondary::after { border: none; }
.btn-text {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: transparent;
  color: #86868b;
  font-size: 28rpx;
  border: none;
}
.btn-text::after { border: none; }
