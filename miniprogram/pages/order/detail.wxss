.order-detail-page {
  min-height: 100vh;
  background: #f8f7f4;
}

.order-detail-body {
  padding: 24rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-status-card,
.order-card {
  border: 2rpx solid #ede6dc;
  border-radius: 44rpx;
  background: linear-gradient(180deg, #fffdfc 0%, #fbf7f0 100%);
  padding: 24rpx 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(24, 17, 10, 0.04);
}

.order-status-card {
  gap: 12rpx;
  display: flex;
  flex-direction: column;
}

.order-status-card__progress {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-status-card__progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: #eee7dd;
  overflow: hidden;
}

.order-status-card__progress-fill {
  width: 42%;
  height: 100%;
  border-radius: 999rpx;
  background: #30343c;
}

.order-status-card__progress-fill--completed {
  width: 100%;
  background: #4ea772;
}

.order-status-card__progress-text {
  font-size: 20rpx;
  color: #9b958b;
}

.order-status-card__top,
.order-card__header,
.order-detail-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-status-card__title,
.order-card__title,
.order-address__receiver,
.order-product__name {
  font-size: 28rpx;
  font-weight: 700;
  color: #20252c;
}

.order-status-card__chip {
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f3ede3;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.order-status-card--completed .order-status-card__chip {
  background: #eef5ef;
}

.order-status-card--completed .order-status-card__chip text {
  color: #4ea772;
}

.order-status-card__chip text,
.order-card__hint,
.order-address__detail,
.order-product__meta,
.order-product__quantity,
.order-info__label,
.order-info__value,
.pay-cancel-text {
  font-size: 20rpx;
  color: #8d867c;
}

.order-status-card__hint,
.order-amounts__label,
.order-amounts__value,
.order-product__price,
.pay-method-name {
  font-size: 24rpx;
  color: #353a42;
}

.order-address__receiver,
.order-address__detail {
  display: block;
}

.order-address__receiver {
  margin-top: 12rpx;
}

.order-address__detail {
  margin-top: 8rpx;
  line-height: 1.55;
}

.order-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-products,
.order-info {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.order-product {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.order-product__thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  background: #efe5d7;
  flex-shrink: 0;
}

.order-product__thumb--placeholder {
  background: #f1eadf;
}

.order-product__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-product__meta {
  line-height: 1.4;
}

.order-product__quantity {
  flex-shrink: 0;
  align-self: flex-end;
}

.order-amounts {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-amounts__row,
.order-info__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.order-amounts__value--emphasis {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #161a20;
}

.order-info__value {
  text-align: right;
  max-width: 360rpx;
}

.order-timeline {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-timeline__item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.order-timeline__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #30343c;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.order-timeline__content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.order-timeline__title {
  font-size: 24rpx;
  font-weight: 600;
  color: #20252c;
}

.order-timeline__meta,
.order-timeline__remark {
  font-size: 20rpx;
  line-height: 1.5;
  color: #8d867c;
}

.order-detail-safe {
  height: 144rpx;
}

.order-detail-bottom {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  bottom: calc(24rpx + constant(safe-area-inset-bottom));
  z-index: 10;
}

.order-detail-bottom__secondary,
.order-detail-bottom__primary {
  height: 84rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-detail-bottom__secondary {
  width: 184rpx;
  background: #f5f1ea;
  border: 2rpx solid #e8e1d7;
}

.order-detail-bottom__secondary text,
.order-detail-bottom__primary text {
  font-size: 24rpx;
  font-weight: 600;
}

.order-detail-bottom__secondary text {
  color: #7a746b;
}

.order-detail-bottom__primary {
  flex: 1;
  background: #30343c;
  box-shadow: 0 18rpx 40rpx rgba(24, 17, 10, 0.1);
}

.order-detail-bottom__primary text {
  color: #ffffff;
}

.pay-overlay {
  position: fixed;
  inset: 0;
  background: rgba(17, 17, 17, 0.16);
  backdrop-filter: blur(12rpx);
  z-index: 20;
}

.pay-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  z-index: 21;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  border-radius: 44rpx 44rpx 0 0;
  background: #fffdf9;
  border: 2rpx solid #eee7de;
  padding: 24rpx 32rpx calc(52rpx + env(safe-area-inset-bottom));
  padding: 24rpx 32rpx calc(52rpx + constant(safe-area-inset-bottom));
  box-shadow: 0 -16rpx 56rpx rgba(24, 17, 10, 0.1);
}

.pay-panel-show {
  transform: translateY(0);
}

.pay-panel-handle {
  width: 96rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #d8cec1;
  margin: 0 auto 28rpx;
}

.pay-panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e2229;
  text-align: center;
}

.pay-amount-wrap {
  padding: 28rpx 0 36rpx;
  text-align: center;
}

.pay-amount-num {
  font-size: 60rpx;
  color: #1f242c;
  font-weight: 700;
}

.pay-method-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 24rpx;
}

.pay-method-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pay-method-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #2dbe60;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-method-icon text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.pay-method-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e6f6e8;
  color: #2dbe60;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.pay-divider {
  height: 2rpx;
  background: #f0ebe2;
  margin-bottom: 28rpx;
}

.pay-confirm-btn {
  width: 100%;
  height: 92rpx;
  background: #30343c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 30rpx;
  border: none;
}

.pay-confirm-btn::after {
  border: none;
}

.pay-cancel-text {
  text-align: center;
  margin-top: 22rpx;
}

.cancel-sheet {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  z-index: 22;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  border-radius: 64rpx 64rpx 0 0;
  background: #fffdf9;
  border: 2rpx solid #eee7de;
  padding: 28rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  padding: 28rpx 40rpx calc(48rpx + constant(safe-area-inset-bottom));
  box-shadow: 0 -16rpx 56rpx rgba(24, 17, 10, 0.1);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cancel-sheet--show {
  transform: translateY(0);
}

.cancel-sheet__handle {
  width: 108rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #d8cec1;
  align-self: center;
}

.cancel-sheet__summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cancel-sheet__title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #1e2229;
}

.cancel-sheet__subtitle {
  font-size: 22rpx;
  color: #969188;
}

.cancel-sheet__reasons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cancel-reason {
  min-height: 104rpx;
  border-radius: 40rpx;
  background: #fffefc;
  border: 2rpx solid #ece5dc;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
}

.cancel-reason--active {
  background: #fff7f2;
  border-color: #f0ded4;
}

.cancel-reason__label {
  font-size: 26rpx;
  color: #2b3138;
  font-weight: 600;
}

.cancel-reason__check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #30343c;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cancel-reason__check text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.cancel-sheet__note {
  border-radius: 36rpx;
  background: #f7f3ed;
  border: 2rpx solid #ece6dc;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cancel-sheet__note-label {
  font-size: 22rpx;
  color: #8a867e;
  font-weight: 600;
}

.cancel-sheet__note-input {
  width: 100%;
  min-height: 72rpx;
  font-size: 24rpx;
  color: #5a5f67;
}

.cancel-sheet__note-placeholder {
  color: #aaa39a;
}

.cancel-sheet__actions {
  height: 96rpx;
  display: flex;
}

.cancel-sheet__secondary,
.cancel-sheet__primary {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-sheet__secondary {
  width: 184rpx;
  border-radius: 20rpx 0 0 20rpx;
  background: #f6f2ec;
}

.cancel-sheet__secondary text {
  font-size: 22rpx;
  color: #767c87;
  font-weight: 600;
}

.cancel-sheet__primary {
  flex: 1;
  border-radius: 0 20rpx 20rpx 0;
  background: #3a3d45;
}

.cancel-sheet__primary text {
  font-size: 24rpx;
  color: #f7f6f3;
  font-weight: 600;
}
