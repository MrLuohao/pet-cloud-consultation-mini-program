/* pages/order/confirm.wxss */
.confirm-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 地址区域 */
.address-section {
  background: #fff;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.address-content {
  flex: 1;
}

.address-header {
  margin-bottom: 15rpx;
}

.receiver-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-right: 20rpx;
}

.receiver-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.no-address {
  flex: 1;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.arrow {
  font-size: 40rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 商品列表 */
.products-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.product-item {
  display: flex;
  margin-bottom: 25rpx;
}

.product-item:last-child {
  margin-bottom: 0;
}

.product-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 30rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.product-quantity {
  font-size: 26rpx;
  color: #999;
}

/* 优惠券区域 */
.coupon-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.coupon-left {
  flex: 1;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.coupon-info {
  font-size: 26rpx;
  color: #ff6b6b;
}

/* 备注区域 */
.remark-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.remark-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
}

/* 价格明细 */
.price-detail {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 26rpx;
  color: #333;
}

.price-value.discount {
  color: #ff6b6b;
}

/* 底部提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: flex-end;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.total-info {
  margin-right: 30rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 25rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.submit-btn::after {
  border: none;
}

/* 优惠券弹窗 */
.coupon-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f5f5f5;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
}

.popup-close {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}

.coupon-list {
  flex: 1;
  padding: 20rpx 30rpx;
  max-height: 60vh;
}

.coupon-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
  border: 1rpx solid #ffebee;
  border-radius: 16rpx;
}

.coupon-amount {
  width: 140rpx;
  text-align: center;
  padding-right: 20rpx;
  border-right: 1rpx dashed #ffcdd2;
}

.amount-symbol {
  font-size: 24rpx;
  color: #ff6b6b;
}

.amount-value {
  font-size: 40rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.coupon-info-wrap {
  flex: 1;
  padding: 0 20rpx;
}

.coupon-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.coupon-desc {
  font-size: 22rpx;
  color: #999;
}

.coupon-select {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coupon-select.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
}

.no-coupon-tip {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
