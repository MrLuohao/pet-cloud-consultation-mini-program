/* pages/community/topic.wxss */

page {
  background: var(--bg-secondary);
}

.topic-page {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding-bottom: 24rpx;
}

.topic-header {
  position: relative;
  background: var(--gradient-primary);
  padding: var(--space-8) var(--space-6);
  padding-top: var(--space-12);
}

.topic-cover {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.topic-cover image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(109, 50, 255, 0.9));
}

.topic-info {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: white;
}

.topic-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-3);
}

.topic-name {
  font-size: var(--font-2xl);
  font-weight: var(--font-bold);
  margin-bottom: var(--space-2);
}

.topic-desc {
  font-size: var(--font-sm);
  opacity: 0.8;
  text-align: center;
  margin-bottom: var(--space-2);
}

.topic-count {
  font-size: var(--font-sm);
  opacity: 0.6;
}

/* 帖子列表 */
.post-list {
  padding: var(--space-4) var(--space-6);
}

.post-card {
  background: var(--bg-primary);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  margin-bottom: var(--space-4);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: var(--space-3);
}

.user-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--neutral-100);
  color: var(--text-secondary);
  font-size: var(--font-sm);
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: var(--font-base);
  font-weight: var(--font-medium);
}

.post-time {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-top: 4rpx;
  line-height: 1.45;
}

.post-signature {
  display: block;
  margin-top: 4rpx;
  font-size: var(--font-xs);
  color: #b0b6c3;
  line-height: 1.45;
}

.post-content {
  font-size: var(--font-base);
  line-height: 1.6;
  margin-bottom: var(--space-3);
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.media-grid {
  display: grid;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.media-grid-1 { grid-template-columns: 1fr; }
.media-grid-2 { grid-template-columns: repeat(2, 1fr); }
.media-grid-3 { grid-template-columns: repeat(3, 1fr); }

.media-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  object-fit: cover;
}

.action-bar {
  display: flex;
  border-top: 1rpx solid var(--border-subtle);
  padding-top: var(--space-3);
}

.action-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.action-item.liked {
  color: var(--primary-500);
}

.loading-status {
  text-align: center;
  padding: var(--space-6);
  color: var(--text-tertiary);
  font-size: var(--font-sm);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-16) 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-4);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  margin-bottom: var(--space-4);
}

.empty-btn {
  padding: var(--space-2) var(--space-6);
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  color: white;
  font-size: var(--font-sm);
}

/* 发布按钮 */
.publish-btn {
  margin: var(--space-2) var(--space-6);
  margin-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
  padding: var(--space-3) var(--space-8);
  background: var(--gradient-primary);
  border-radius: var(--radius-full);
  color: white;
  font-size: var(--font-base);
  font-weight: var(--font-medium);
  box-shadow: var(--shadow-sm);
  text-align: center;
}
