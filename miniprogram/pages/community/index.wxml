<!-- pages/community/index.wxml - 宠物社区（Story 5.3）-->
<view class="community-page">

  <!-- 顶部 -->
  <view class="community-header">
    <text class="header-title">宠物社区</text>
    <view class="post-btn" bindtap="onOpenPost">
      <text class="post-btn-icon">✏️</text>
      <text class="post-btn-text">发帖</text>
    </view>
  </view>

  <!-- 帖子列表 -->
  <view class="post-list">
    <view wx:for="{{posts}}" wx:key="id" class="post-card">
      <!-- 用户信息 -->
      <view class="post-user">
        <image class="user-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="user-meta">
          <text class="user-name">{{item.nickname || '宠物主人'}}</text>
          <text class="post-time">{{item.createTime}}</text>
        </view>
        <view wx:if="{{item.petName}}" class="pet-badge">🐾 {{item.petName}}</view>
      </view>

      <!-- 帖子内容 -->
      <text class="post-content">{{item.content}}</text>

      <!-- 图片 -->
      <view wx:if="{{item.mediaUrls && item.mediaUrls.length > 0}}" class="media-grid media-grid-{{item.mediaUrls.length > 1 ? 'multi' : 'single'}}">
        <image
          wx:for="{{item.mediaUrls}}"
          wx:key="index"
          wx:for-item="url"
          class="media-img"
          src="{{url}}"
          mode="aspectFill"
          bindtap="onPreviewMedia"
          data-urls="{{item.mediaUrls}}"
          data-current="{{url}}"
        />
      </view>

      <!-- 互动区 -->
      <view class="post-actions">
        <view
          class="action-item {{item.isLiked ? 'action-liked' : ''}}"
          bindtap="onToggleLike"
          data-id="{{item.id}}"
          data-isliked="{{item.isLiked}}"
          data-idx="{{index}}"
        >
          <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
          <text class="action-count">{{item.likeCount || 0}}</text>
        </view>
        <view
          class="action-item"
          bindtap="onOpenComments"
          data-post="{{item}}"
          data-idx="{{index}}"
        >
          <text class="action-icon">💬</text>
          <text class="action-count">{{item.commentCount || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="loading-more">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:elif="{{!hasMore && posts.length > 0}}" class="no-more">
      <text class="no-more-text">—— 已加载全部 ——</text>
    </view>
    <view wx:elif="{{!loading && posts.length === 0}}" class="empty-state">
      <text class="empty-icon">🐾</text>
      <text class="empty-text">还没有帖子，来发第一篇吧</text>
    </view>
  </view>

  <!-- 发帖弹窗 -->
  <view wx:if="{{showPostModal}}" class="modal-mask" bindtap="onClosePost">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">发布动态</text>
        <text class="modal-close" bindtap="onClosePost">✕</text>
      </view>
      <textarea
        class="post-textarea"
        placeholder="分享你和宠物的精彩时刻..."
        value="{{newPostContent}}"
        bindinput="onPostInput"
        maxlength="500"
        auto-height
        focus="{{showPostModal}}"
      />
      <view class="img-upload-row">
        <view wx:for="{{newPostImages}}" wx:key="index" class="upload-thumb">
          <image class="thumb-img" src="{{item}}" mode="aspectFill"/>
          <view class="thumb-remove" bindtap="onRemovePostImage" data-index="{{index}}">×</view>
        </view>
        <view wx:if="{{newPostImages.length < 6}}" class="add-thumb" bindtap="onAddPostImage">
          <text class="add-thumb-icon">+</text>
        </view>
      </view>
      <view class="modal-footer">
        <text class="char-hint">{{newPostContent.length}}/500</text>
        <button
          class="publish-btn {{posting ? 'btn-disabled' : ''}}"
          bindtap="onSubmitPost"
          disabled="{{posting}}"
        >{{posting ? '发布中...' : '发布'}}</button>
      </view>
    </view>
  </view>

  <!-- 评论弹窗 -->
  <view wx:if="{{showCommentModal}}" class="modal-mask" bindtap="onCloseComments">
    <view class="comment-modal" catchtap="">
      <view class="modal-header">
        <text class="modal-title">评论 ({{activePost.commentCount || 0}})</text>
        <text class="modal-close" bindtap="onCloseComments">✕</text>
      </view>
      <scroll-view class="comment-list" scroll-y>
        <view wx:if="{{loadingComments}}" class="comment-loading">加载中...</view>
        <view wx:elif="{{comments.length === 0}}" class="comment-empty">暂无评论，来说点什么吧</view>
        <view wx:else>
          <view wx:for="{{comments}}" wx:key="id" class="comment-item">
            <image class="comment-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
            <view class="comment-body">
              <text class="comment-name">{{item.nickname || '用户'}}</text>
              <text class="comment-text">{{item.content}}</text>
              <text class="comment-time">{{item.createTime}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="comment-input-bar">
        <input
          class="comment-input"
          placeholder="说点什么..."
          value="{{commentInput}}"
          bindinput="onCommentInput"
          confirm-type="send"
          bindconfirm="onSendComment"
        />
        <button class="send-btn" bindtap="onSendComment">发送</button>
      </view>
    </view>
  </view>

</view>
