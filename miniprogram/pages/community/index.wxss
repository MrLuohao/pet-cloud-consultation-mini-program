/* pages/community/index.wxss */
.community-page {
  min-height: 100vh;
  background: #f5f5f7;
}

/* 头部 */
.community-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.header-title { font-size: 36rpx; font-weight: 700; color: #1d1d1f; }
.post-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
}
.post-btn-icon { font-size: 28rpx; }
.post-btn-text { font-size: 26rpx; color: #fff; font-weight: 500; }

/* 帖子列表 */
.post-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.post-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 用户信息 */
.post-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.user-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #f5f5f7; flex-shrink: 0; }
.user-meta { flex: 1; }
.user-name { display: block; font-size: 28rpx; font-weight: 600; color: #1d1d1f; }
.post-time { display: block; font-size: 22rpx; color: #aeaeb2; margin-top: 4rpx; }
.pet-badge {
  font-size: 22rpx;
  color: #667eea;
  background: #f0f0ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 内容 */
.post-content {
  display: block;
  font-size: 28rpx;
  color: #1d1d1f;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

/* 图片网格 */
.media-grid { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; }
.media-grid-single .media-img { width: 400rpx; height: 300rpx; border-radius: 12rpx; object-fit: cover; }
.media-grid-multi .media-img { width: 220rpx; height: 220rpx; border-radius: 12rpx; object-fit: cover; }

/* 互动区 */
.post-actions {
  display: flex;
  gap: 40rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f7;
}
.action-item { display: flex; align-items: center; gap: 8rpx; }
.action-icon { font-size: 32rpx; }
.action-count { font-size: 24rpx; color: #86868b; }
.action-liked .action-count { color: #ff3b30; }

/* 加载/空状态 */
.loading-more, .no-more { text-align: center; padding: 32rpx 0; }
.loading-text, .no-more-text { font-size: 24rpx; color: #aeaeb2; }
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #86868b; }

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.comment-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #1d1d1f; }
.modal-close { font-size: 36rpx; color: #aeaeb2; padding: 8rpx; }

.post-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.img-upload-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.upload-thumb {
  position: relative;
  width: 160rpx; height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.thumb-img { width: 100%; height: 100%; object-fit: cover; }
.thumb-remove {
  position: absolute;
  top: 4rpx; right: 4rpx;
  width: 36rpx; height: 36rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-thumb {
  width: 160rpx; height: 160rpx;
  border: 2rpx dashed #d1d1d6;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-thumb-icon { font-size: 56rpx; color: #aeaeb2; }

.modal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.char-hint { font-size: 22rpx; color: #aeaeb2; }
.publish-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0 40rpx;
  height: 72rpx;
  line-height: 72rpx;
}
.publish-btn::after { border: none; }
.btn-disabled { background: #ccc; }

/* 评论弹窗 */
.comment-list {
  flex: 1;
  padding: 0 32rpx;
  max-height: 50vh;
}
.comment-loading, .comment-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #aeaeb2;
}
.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f7;
}
.comment-avatar { width: 60rpx; height: 60rpx; border-radius: 50%; flex-shrink: 0; }
.comment-body { flex: 1; }
.comment-name { display: block; font-size: 26rpx; font-weight: 600; color: #1d1d1f; margin-bottom: 6rpx; }
.comment-text { display: block; font-size: 26rpx; color: #3d3d3f; line-height: 1.6; margin-bottom: 6rpx; }
.comment-time { display: block; font-size: 22rpx; color: #aeaeb2; }

.comment-input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}
.comment-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f7;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1d1d1f;
}
.send-btn {
  background: #667eea;
  color: #fff;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
}
.send-btn::after { border: none; }
