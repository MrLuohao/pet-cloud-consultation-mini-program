/* pages/diagnosis/diagnosis.wxss - AI诊断页面样式 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F9FC 0%, #F5F5F7 100%);
  display: flex;
  flex-direction: column;
}

/* ==================== 容器 ==================== */
.container {
  flex: 1;
  padding: 16px 24rpx 160rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

/* ==================== 介绍卡片 ==================== */
.intro-card {
  position: relative;
  background: linear-gradient(135deg, #6D32FF 0%, #A855F7 50%, #EC4899 100%);
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(109, 50, 255, 0.3);
  transition: all 0.5s ease;
}

.intro-card:active {
  transform: scale(0.99);
}

/* Hero 背景 */
.intro-card .hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
  z-index: 0;
}

.intro-card .hero-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(109, 50, 255, 0.1) 0%, rgba(168, 85, 247, 0.15) 50%, rgba(236, 72, 153, 0.1) 100%);
}

.intro-card .hero-orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  filter: blur(40rpx);
}

.intro-card .hero-orb-1 {
  width: 200rpx;
  height: 200rpx;
  top: -40rpx;
  right: -40rpx;
  background: rgba(168, 133, 255, 0.3);
}

.intro-card .hero-orb-2 {
  width: 160rpx;
  height: 160rpx;
  bottom: -30rpx;
  left: 20%;
  background: rgba(236, 72, 153, 0.25);
}

.intro-card .hero-orb-3 {
  width: 120rpx;
  height: 120rpx;
  bottom: 40%;
  right: 10%;
  background: rgba(59, 130, 246, 0.2);
}

.intro-card .hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
}

/* 内容 */
.intro-content {
  position: relative;
  z-index: 2;
}

.intro-icon {
  font-size: 88rpx;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
  animation: floatIcon 3s ease-in-out infinite;
}

@keyframes floatIcon {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.intro-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
  position: relative;
  z-index: 1;
}

.intro-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  position: relative;
  z-index: 1;
}

/* ==================== 表单区域 ==================== */
.form-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04), 0 0 1rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 24rpx;
}

.required {
  color: #FF3B30;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #1D1D1F;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1D1D1F;
}

.symptom-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1D1D1F;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #86868B;
  margin-top: 8rpx;
}

/* ==================== 宠物类型选择器 ==================== */
.pet-type-selector {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  border: 2px solid transparent;
  transition: all 0.2s ease;
}

.type-item.active {
  background: rgba(109, 50, 255, 0.08);
  border-color: #6D32FF;
  box-shadow: 0 0 0 4rpx rgba(109, 50, 255, 0.08);
}

.type-icon {
  font-size: 48rpx;
}

.type-name {
  font-size: 24rpx;
  color: #1D1D1F;
}

/* ==================== 快捷症状标签 ==================== */
.quick-symptoms {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.symptom-tag {
  padding: 12rpx 24rpx;
  background: #F5F5F7;
  border-radius: 36rpx;
  font-size: 24rpx;
  color: #86868B;
  border: 1px solid transparent;
  transition: all 0.2s ease;
}

.symptom-tag.active {
  background: rgba(109, 50, 255, 0.08);
  color: #6D32FF;
  border-color: rgba(109, 50, 255, 0.3);
}

/* ==================== 图片上传 ==================== */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  border: 2px dashed #C7C7CC;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #86868B;
}

.uploaded-images {
  position: relative;
  margin-top: 16rpx;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.remove-image {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 48rpx;
  height: 48rpx;
  background: #FF3B30;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
}

/* ==================== 免责声明 ==================== */
.disclaimer {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #FF9500;
  line-height: 1.6;
}

/* ==================== 诊断结果 ==================== */
.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.result-icon {
  font-size: 36rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.result-content {
  background: #EEF6FC;
  border-radius: 16rpx;
  padding: 24rpx;
}

.result-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #1D1D1F;
  white-space: pre-wrap;
}

/* ==================== Markdown内容样式 ==================== */
.markdown-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.75;
}

.md-heading {
  font-weight: 600;
  color: #111827;
  line-height: 1.4;
}

.md-heading-1 {
  font-size: 32rpx;
}

.md-heading-2 {
  font-size: 30rpx;
}

.md-heading-3 {
  font-size: 28rpx;
}

.md-paragraph {
  font-size: 28rpx;
  line-height: 1.75;
  color: #374151;
}

.md-bold {
  font-weight: 600;
  color: #111827;
}

.md-list-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 0;
  background: transparent;
  margin: 0;
}

.md-list-marker {
  flex-shrink: 0;
  min-width: 32rpx;
  height: auto;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  background: transparent;
  border-radius: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #6B7280;
  padding-top: 2rpx;
}

.md-bullet {
  font-size: 28rpx;
  color: #6B7280;
}

.md-list-content {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.75;
  color: #374151;
  padding-top: 0;
}

.md-list-content .md-bold {
  color: #111827;
  font-weight: 600;
}

/* ==================== 底部占位 ==================== */
.bottom-placeholder {
  height: 20rpx;
}

/* ==================== 底部按钮栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 0.5px solid rgba(0, 0, 0, 0.06);
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.diagnose-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #6D32FF 0%, #A855F7 100%);
  border-radius: 50rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(109, 50, 255, 0.35);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.diagnose-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(109, 50, 255, 0.25);
}

.diagnose-btn.loading {
  opacity: 0.7;
}

.diagnose-btn[disabled] {
  opacity: 0.5;
}
