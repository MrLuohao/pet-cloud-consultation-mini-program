<!--pages/address/list.wxml-->
<view class="address-container">
  <!-- 地址列表 -->
  <view class="address-list">
    <view class="address-item" wx:for="{{addressList}}" wx:key="id" bindtap="selectAddress" data-id="{{item.id}}">
      <view class="address-header">
        <view class="contact-info">
          <text class="contact-name">{{item.contactName}}</text>
          <text class="contact-phone">{{item.contactPhone}}</text>
        </view>
        <view class="default-badge" wx:if="{{item.isDefault}}">默认</view>
      </view>
      <view class="address-content">{{item.fullAddress}}</view>
      <view class="address-actions" catchtap="stopPropagation">
        <button class="action-btn" bindtap="editAddress" data-id="{{item.id}}">编辑</button>
        <button class="action-btn delete" bindtap="deleteAddress" data-id="{{item.id}}" wx:if="{{!item.isDefault}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{addressList.length === 0}}">
    <text class="empty-text">暂无收货地址</text>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="addAddress">
    <text>+ 新增收货地址</text>
  </view>
</view>
