<view class="address-edit-page">
  <view class="address-edit-body">
    <view class="address-edit-acquire">
      <view class="address-edit-acquire__header">
        <view class="address-edit-acquire__copy">
          <text class="address-edit-acquire__title">完善收货资料</text>
          <text class="address-edit-acquire__sub">用于下单、配送与地址确认</text>
        </view>
        <view class="address-edit-acquire__action" bindtap="chooseLocation">
          <text>地图选点</text>
        </view>
      </view>

      <view class="address-edit-search">
        <input
          class="address-edit-search__input"
          placeholder="搜索地点，地图将自动切换"
          placeholder-class="address-edit-search__placeholder"
          value="{{searchKeyword}}"
          bindinput="onSearchKeywordInput"
          confirm-type="search"
        />
        <text wx:if="{{searchLoading}}" class="address-edit-search__state">搜索中…</text>
      </view>

      <view wx:if="{{searchSuggestions.length > 0}}" class="address-edit-search-list">
        <view
          wx:for="{{searchSuggestions}}"
          wx:key="id"
          class="address-edit-search-list__item"
          data-index="{{index}}"
          bindtap="selectSearchSuggestion"
        >
          <text class="address-edit-search-list__title">{{item.name}}</text>
          <text class="address-edit-search-list__detail">{{item.address}}</text>
        </view>
      </view>

      <view class="address-edit-map">
        <map
          class="address-edit-map__native"
          latitude="{{mapPreview.latitude}}"
          longitude="{{mapPreview.longitude}}"
          scale="{{mapPreview.scale}}"
          rotate="{{mapPreview.rotate}}"
          skew="{{mapPreview.skew}}"
          markers="{{mapPreview.markers}}"
          show-location="{{mapPreview.showLocation}}"
          enable-3D="{{mapPreview.enable3d}}"
          enable-overlooking="{{mapPreview.enableOverlooking}}"
        ></map>
        <view class="address-edit-map__chip">{{mapHint}}</view>
        <view class="address-edit-map__info">{{mapTitle}}</view>
      </view>

      <view class="address-edit-parse">
        <view class="address-edit-parse__top">
          <text class="address-edit-parse__title">粘贴完整地址，自动识别</text>
          <view class="address-edit-parse__badge">
            <text>已识别 {{parseCount}} 项</text>
          </view>
        </view>
        <textarea
          class="address-edit-parse__input"
          placeholder="粘贴完整地址与联系人信息"
          placeholder-class="address-edit-parse__placeholder"
          value="{{pasteText}}"
          maxlength="-1"
          auto-height
          bindinput="onPasteInput"
          bindblur="onPasteBlur"
        />
      </view>
    </view>

    <view class="address-edit-form">
      <view class="address-edit-form__dual">
        <view class="address-field">
          <text class="address-field__label">联系人</text>
          <input
            class="address-field__input"
            placeholder="请输入联系人姓名"
            placeholder-class="address-field__placeholder"
            value="{{formData.contactName}}"
            bindinput="onInputChange"
            data-field="contactName"
          />
        </view>

        <view class="address-field">
          <text class="address-field__label">手机号</text>
          <input
            class="address-field__input"
            type="number"
            placeholder="请输入手机号"
            placeholder-class="address-field__placeholder"
            value="{{formData.contactPhone}}"
            bindinput="onInputChange"
            data-field="contactPhone"
          />
        </view>
      </view>

      <view class="address-field address-field--region">
        <text class="address-field__label">所在地区</text>
        <picker mode="region" value="{{region}}" bindchange="onRegionChange">
          <view class="address-field__picker">
            <text>{{regionText}}</text>
          </view>
        </picker>
      </view>

      <view class="address-field address-field--detail">
        <text class="address-field__label">详细地址</text>
        <textarea
          class="address-field__textarea"
          placeholder="请填入街道、小区、楼栋门牌等详细信息"
          placeholder-class="address-field__placeholder"
          value="{{formData.detailAddress}}"
          maxlength="-1"
          auto-height
          bindinput="onInputChange"
          data-field="detailAddress"
        />
        <text class="address-field__hint">{{detailHint}}</text>
      </view>

      <view class="address-default" bindtap="onDefaultToggle">
        <view class="address-default__copy">
          <text class="address-default__title">设为默认地址</text>
          <text class="address-default__sub">下单时会优先使用这条地址</text>
        </view>
        <view class="address-default__switch {{formData.isDefault ? 'address-default__switch--on' : ''}}">
          <view class="address-default__switch-dot"></view>
        </view>
      </view>
    </view>

    <view class="address-edit-safe"></view>
  </view>

  <view class="address-edit-bottom">
    <view class="address-edit-bottom__button" bindtap="saveAddress">
      <text>保存地址</text>
    </view>
    <text class="address-edit-bottom__sub">保存后可在地址列表页继续切换或设为下单地址</text>
  </view>
</view>
