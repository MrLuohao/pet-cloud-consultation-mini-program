.feedback-page { padding: 24rpx; background: #f6f7fb; min-height: 100vh; box-sizing: border-box; }
.card { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 20rpx; }
.field { margin-bottom: 18rpx; }
.label { display: block; font-size: 26rpx; color: #374151; margin-bottom: 8rpx; }
.picker, .input { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10rpx; min-height: 72rpx; padding: 16rpx; box-sizing: border-box; }
.textarea { width: 100%; min-height: 180rpx; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 10rpx; padding: 16rpx; box-sizing: border-box; }
.shots { display: flex; flex-wrap: wrap; gap: 12rpx; }
.shot, .add-shot { width: 160rpx; height: 160rpx; border-radius: 10rpx; overflow: hidden; position: relative; }
.shot image { width: 100%; height: 100%; }
.remove { position: absolute; top: 0; right: 0; background: rgba(0,0,0,0.6); color: #fff; width: 36rpx; height: 36rpx; text-align: center; line-height: 36rpx; }
.add-shot { border: 1px dashed #cbd5e1; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 56rpx; }
.title { font-size: 28rpx; font-weight: 600; margin-bottom: 8rpx; }
.msg { border-bottom: 1px solid #f1f2f4; padding: 12rpx 0; }
.msg:last-child { border-bottom: none; }
.msg-title { display: block; font-size: 26rpx; color: #111827; }
.msg-content { display: block; font-size: 24rpx; color: #6b7280; margin-top: 6rpx; }
.empty { font-size: 24rpx; color: #9ca3af; }
