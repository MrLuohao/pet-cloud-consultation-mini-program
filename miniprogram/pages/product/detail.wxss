/* pages/product/detail.wxss */

/* ==================== 页面容器 ==================== */
.product-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #f0f2f5 100%);
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 商品轮播 ==================== */
.swiper-wrapper {
  position: relative;
  width: 100%;
  height: 750rpx;
}

.product-swiper {
  width: 100%;
  height: 100%;
  background: #fff;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.swiper-indicator {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  z-index: 10;
}

.swiper-indicator text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* ==================== 商品信息卡片 ==================== */
.product-card {
  background: #fff;
  margin: -40rpx 24rpx 20rpx;
  padding: 36rpx;
  border-radius: 24rpx;
  position: relative;
  z-index: 20;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

/* 价格区域 */
.price-section {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
}

.price-main {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  color: #ff4757;
  font-weight: 600;
}

.price-integer {
  font-size: 56rpx;
  color: #ff4757;
  font-weight: 700;
  line-height: 1;
  margin-left: 4rpx;
}

.price-decimal {
  font-size: 32rpx;
  color: #ff4757;
  font-weight: 600;
}

.price-extra {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  margin-bottom: 8rpx;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}

/* 销量信息 */
.sales-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.sales-text {
  font-size: 26rpx;
  color: #999;
}

.guarantee-tags {
  display: flex;
  gap: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.tag-icon {
  font-size: 22rpx;
  color: #667eea;
}

.tag-item text:last-child {
  font-size: 24rpx;
  color: #666;
}

/* 商品标题 */
.product-title {
  font-size: 34rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.product-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* ==================== 服务保障 ==================== */
.service-card {
  background: #fff;
  margin: 0 24rpx 20rpx;
  padding: 28rpx 36rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.service-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.service-icon {
  font-size: 32rpx;
}

.service-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.service-divider {
  width: 1rpx;
  height: 32rpx;
  background: #eee;
}

/* ==================== 评价卡片 ==================== */
.review-card {
  background: #fff;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.review-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-text {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.rating-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  gap: 4rpx;
}

.rating-value {
  font-size: 26rpx;
  color: #ff9800;
  font-weight: 600;
}

.rating-star {
  font-size: 24rpx;
  color: #ff9800;
}

.review-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.review-more text:first-child {
  font-size: 26rpx;
  color: #999;
}

.arrow-icon {
  font-size: 32rpx;
  color: #ccc;
}

/* 评价预览 */
.review-preview {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.preview-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.preview-avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.preview-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.preview-content {
  flex: 1;
  background: #f8f9fa;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.preview-user-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.preview-username {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.preview-rating {
  display: flex;
  gap: 4rpx;
}

.preview-star {
  font-size: 22rpx;
  color: #ddd;
}

.preview-star.active {
  color: #ff9500;
}

.preview-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 评价图片预览 */
.preview-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.preview-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

/* ==================== 数量选择 ==================== */
.quantity-card {
  background: #fff;
  margin: 0 24rpx 20rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.quantity-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.quantity-label {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.stock-text {
  font-size: 24rpx;
  color: #52c41a;
}

.stock-text.low {
  color: #faad14;
}

.stock-text.out {
  color: #ff4757;
}

.quantity-control {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  overflow: hidden;
}

.qty-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.qty-btn text {
  font-size: 36rpx;
  color: #333;
  font-weight: 300;
}

.qty-btn.disabled {
  opacity: 0.3;
}

.qty-btn:active:not(.disabled) {
  background: #e8e8e8;
}

.qty-input {
  width: 80rpx;
  height: 72rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  background: transparent;
}

/* ==================== 底部占位 ==================== */
.bottom-placeholder {
  height: 40rpx;
}

/* ==================== 底部操作栏 ==================== */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  padding-bottom: calc(12rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 1000;
}

/* 图标区域 */
.action-icons {
  display: flex;
  align-items: center;
}

.action-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  padding: 4rpx 0;
  transition: all 0.2s;
}

.action-icon-item:active {
  opacity: 0.7;
}

.icon-wrapper {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 40rpx;
  line-height: 1;
}

.icon-heart {
  font-size: 42rpx;
  line-height: 1;
  color: #999;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.icon-heart.collected {
  color: #ff4757;
  animation: heartPulse 0.4s ease;
}

@keyframes heartPulse {
  0% { transform: scale(1); }
  25% { transform: scale(1.3); }
  50% { transform: scale(0.95); }
  75% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.icon-label {
  font-size: 20rpx;
  color: #666;
  margin-top: 2rpx;
  white-space: nowrap;
}

.action-icon-item.active .icon-label {
  color: #ff4757;
}

/* 购物车角标 */
.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: linear-gradient(135deg, #ff6b81 0%, #ff4757 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  font-size: 18rpx;
  color: #fff;
  font-weight: 600;
}

/* 按钮区域 */
.action-buttons {
  flex: 1;
  display: flex;
  margin-left: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.action-btn:active {
  opacity: 0.9;
}

.action-btn text {
  font-size: 28rpx;
  font-weight: 600;
}

.cart-btn {
  background: linear-gradient(135deg, #ffd93d 0%, #ffb800 100%);
  border-radius: 40rpx 0 0 40rpx;
}

.cart-btn text {
  color: #1a1a1a;
}

.buy-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4757 100%);
  border-radius: 0 40rpx 40rpx 0;
}

.buy-btn text {
  color: #fff;
}

/* ==================== 动画效果 ==================== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.product-card,
.service-card,
.review-card,
.quantity-card {
  animation: fadeInUp 0.5s ease backwards;
}

.service-card {
  animation-delay: 0.1s;
}

.review-card {
  animation-delay: 0.15s;
}

.quantity-card {
  animation-delay: 0.2s;
}

/* ==================== 写评价按钮 ==================== */
.write-review-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  transition: all 0.3s;
}

.write-review-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.write-icon {
  font-size: 28rpx;
}

.write-review-btn text:last-child {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* ==================== 写评价弹窗 ==================== */
.review-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.review-popup {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 28rpx;
  color: #999;
}

/* 订单商品信息 */
.order-product-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.order-product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.order-product-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.order-product-price {
  font-size: 26rpx;
  color: #999;
}

/* 评分 */
.rating-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.rating-stars {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 48rpx;
  color: #ddd;
  transition: all 0.2s;
}

.star.active {
  color: #ff9500;
}

/* 评价内容 */
.content-section {
  position: relative;
  margin-bottom: 24rpx;
}

.review-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: #999;
}

/* 图片上传 */
.image-section {
  margin-bottom: 32rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.add-image-btn {
  width: 180rpx;
  height: 180rpx;
  background: #f8f9fa;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  transition: all 0.3s;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
