.task-page {
  padding: 24rpx;
  background: #f7f8fa;
  min-height: 100vh;
  box-sizing: border-box;
}

.points-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  color: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.points-title {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.points-value {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  margin: 12rpx 0;
}

.points-sub {
  display: block;
  font-size: 24rpx;
  opacity: 0.85;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #222;
}

.task-item,
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid #f1f2f4;
}

.task-item:last-child,
.history-item:last-child {
  border-bottom: none;
}

.task-main,
.history-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  padding-right: 16rpx;
}

.task-name,
.history-title {
  font-size: 28rpx;
  color: #222;
}

.task-desc,
.history-time {
  font-size: 24rpx;
  color: #888;
}

.task-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.task-points,
.history-points {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff6b35;
}

.empty {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 28rpx 0;
}
