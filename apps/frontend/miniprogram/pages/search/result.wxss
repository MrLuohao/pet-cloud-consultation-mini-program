/* pages/search/result.wxss */
.search-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索框 */
.search-bar {
  background: #fff;
  padding: 20rpx 30rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 40rpx;
  color: #999;
  margin-left: 15rpx;
  line-height: 1;
}

/* 热门搜索 */
.hot-section {
  background: #fff;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.hot-keywords {
  display: flex;
  flex-wrap: wrap;
}

.keyword-item {
  padding: 15rpx 30rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
  margin-bottom: 15rpx;
}

/* 搜索中提示 */
.searching-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 150rpx;
}

.searching-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: var(--primary-500, #6D32FF);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.searching-text {
  font-size: 28rpx;
  color: #999;
}

/* 搜索结果 */
.result-section {
  padding: 20rpx 30rpx;
}

.result-header {
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 26rpx;
  color: #999;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
}

.product-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-item:nth-child(odd) {
  margin-right: 20rpx;
}

.product-cover {
  width: 100%;
  height: 300rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.product-summary {
  font-size: 22rpx;
  color: #999;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  padding-top: 200rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
  display: block;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}
