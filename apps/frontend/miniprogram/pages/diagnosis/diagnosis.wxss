.diagnosis-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.diagnosis-scroll {
  height: 100vh;
}

.diagnosis-shell {
  padding: 24rpx 32rpx 40rpx;
}

.section-head,
.pet-type-row,
.field-row {
  display: flex;
  align-items: center;
}

.hero-card,
.section-card,
.note-card,
.result-card {
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 40rpx;
  border: 1rpx solid #f2edf8;
}

.hero-card {
  padding: 32rpx;
}

.hero-title,
.section-title,
.result-label {
  color: #1f2937;
  font-weight: 700;
}

.hero-title {
  font-size: 40rpx;
  line-height: 1.25;
}

.hero-desc,
.record-hint,
.upload-hint,
.note-text,
.cta-hint,
.result-text,
.result-list-item {
  color: #7c8395;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.section-card,
.result-card {
  padding: 32rpx;
}

.section-card-soft {
  background: #fcfcfd;
  border-color: #eeeaf5;
}

.section-head {
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 30rpx;
}

.section-title.subtle {
  color: #4b5563;
}

.section-link {
  color: #b1a7c9;
  font-size: 22rpx;
  font-weight: 600;
}

.record-meta {
  display: block;
  margin-top: 14rpx;
  color: #6d32ff;
  font-size: 24rpx;
  font-weight: 600;
}

.record-line,
.record-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.tag-row,
.uploaded-grid {
  display: flex;
  flex-wrap: wrap;
}

.tag-row {
  gap: 12rpx;
  margin-top: 18rpx;
}

.symptom-tag,
.pet-type-pill {
  border-radius: 999rpx;
  background: #f7f7fa;
}

.symptom-tag {
  padding: 14rpx 20rpx;
}

.symptom-tag text {
  color: #7b8190;
  font-size: 22rpx;
  font-weight: 600;
}

.symptom-tag.active {
  background: #f5f1ff;
}

.symptom-tag.active text {
  color: #6d32ff;
}

.textarea-wrap {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fafafc;
  border: 1rpx solid #eeeaf5;
}

.symptom-textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #4b5563;
}

.textarea-count {
  display: block;
  margin-top: 12rpx;
  text-align: right;
  color: #c0c5d0;
  font-size: 20rpx;
}

.upload-area {
  margin-top: 18rpx;
  padding: 32rpx 24rpx;
  border-radius: 36rpx;
  background: #fafafc;
  border: 1rpx solid #e8e3f4;
  text-align: center;
}

.upload-glyph {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 14rpx;
  border-radius: 40rpx;
  background: #f3eeff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-glyph text {
  color: #6d32ff;
  font-size: 40rpx;
  font-weight: 700;
}

.upload-label {
  display: block;
  color: #6d32ff;
  font-size: 26rpx;
  font-weight: 600;
}

.upload-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.5;
}

.uploaded-grid {
  gap: 16rpx;
  margin-top: 16rpx;
}

.uploaded-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.remove-image {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-image text {
  color: #ffffff;
  font-size: 24rpx;
}

.pet-type-row {
  gap: 14rpx;
  margin-top: 18rpx;
}

.pet-type-pill {
  flex: 1;
  padding: 18rpx 0;
  text-align: center;
  border: 1rpx solid transparent;
}

.pet-type-pill text {
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 600;
}

.pet-type-pill.active {
  background: #f7f4ff;
  border-color: #e2d6ff;
}

.pet-type-pill.active text {
  color: #6d32ff;
}

.field-row {
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid #eeeaf5;
  background: #ffffff;
}

.field-label {
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 600;
}

.field-input {
  width: 180rpx;
  text-align: right;
  color: #4b5563;
  font-size: 26rpx;
}

.note-card {
  padding: 28rpx;
  background: #fff9f2;
  border-color: #f4e2c8;
}

.note-title {
  display: block;
  color: #9b6a19;
  font-size: 26rpx;
  font-weight: 700;
}

.note-text {
  display: block;
  margin-top: 10rpx;
  color: #8a6f46;
  font-size: 22rpx;
  line-height: 1.55;
}

.cta-wrap {
  margin-top: 18rpx;
  text-align: center;
}

.submit-btn {
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  background: #6d32ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.is-loading {
  opacity: 0.8;
}

.cta-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
}

.result-risk {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: #f6f2ff;
  color: #6d32ff;
}

.result-block {
  margin-top: 20rpx;
}

.result-label {
  display: block;
  font-size: 24rpx;
}

.result-text,
.result-list-item {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
}
