/* pages/insurance/index.wxss */
.insurance-page {
  min-height: 100vh;
  background: #f5f5f7;
}

/* ==================== Hero ==================== */
.hero-section {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 40rpx;
}

.coming-badge {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx;
}

.hero-icons {
  display: flex;
  gap: 16rpx;
  font-size: 44rpx;
}

/* ==================== 亮点 ==================== */
.highlights-section {
  background: #fff;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 24rpx;
}

.highlights-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.highlight-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f8f8fa;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}

.highlight-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.highlight-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 6rpx;
}

.highlight-desc {
  font-size: 22rpx;
  color: #999;
}

/* ==================== 险种 ==================== */
.products-section {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.product-card {
  position: relative;
  background: #f8f8fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.product-card:last-child {
  margin-bottom: 0;
}

.product-lock {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  filter: blur(2rpx);
}

.product-left {
  display: flex;
  align-items: center;
}

.product-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.product-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.product-tag {
  font-size: 20rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999;
}

.product-price-wrap {
  display: flex;
  align-items: baseline;
}

.product-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.product-unit {
  font-size: 22rpx;
  color: #999;
}

.lock-mask {
  position: absolute;
  inset: 0;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.lock-icon {
  font-size: 28rpx;
}

.lock-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* ==================== 预约通知 ==================== */
.notify-section {
  padding: 0 24rpx 60rpx;
}

.notify-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.notify-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.notify-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.notify-btn {
  background: #fff;
  color: #667eea;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  height: 88rpx;
  padding: 0 64rpx;
}

.notify-btn::after {
  border: none;
}
