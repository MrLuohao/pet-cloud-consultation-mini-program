<view class="confirm-page">
  <view class="confirm-body">
    <view class="confirm-address" bindtap="selectAddress">
      <view class="confirm-address__top">
        <view class="confirm-address__receiver-group">
          <text class="confirm-address__receiver">{{address ? address.contactName : '请选择收货地址'}}</text>
          <text wx:if="{{address}}" class="confirm-address__phone">{{address.contactPhoneDisplay || address.contactPhone}}</text>
        </view>
        <text class="confirm-address__arrow">›</text>
      </view>
      <text class="confirm-address__detail">
        {{address ? address.fullAddress : '补充地址后可继续完成支付'}}
      </text>
      <view class="confirm-address__divider"></view>
    </view>

    <view class="confirm-products">
      <view class="confirm-product" wx:for="{{orderItems}}" wx:key="productId">
        <image
          wx:if="{{item.coverUrl}}"
          class="confirm-product__thumb"
          src="{{item.coverUrl}}"
          mode="aspectFill"
        ></image>
        <view wx:else class="confirm-product__thumb confirm-product__thumb--placeholder">
          <image class="confirm-product__fallback-icon" src="{{item.fallbackIcon}}" mode="aspectFit"></image>
        </view>
        <view class="confirm-product__info">
          <text class="confirm-product__name">{{item.productName}}</text>
          <text class="confirm-product__meta">{{item.spec || '默认规格'}}</text>
          <view class="confirm-product__price-row">
            <text class="confirm-product__price">¥{{item.price}}</text>
            <text class="confirm-product__qty">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="confirm-settings">
      <view class="confirm-settings__row" bindtap="selectCoupon">
        <text class="confirm-settings__label">优惠</text>
        <text class="confirm-settings__value">
          {{couponDiscount !== '0.00' ? '已优惠 ¥' + couponDiscount : selectedCoupon ? selectedCoupon.couponName : '已优惠 ¥0'}}
        </text>
      </view>
      <view class="confirm-settings__row">
        <text class="confirm-settings__label">备注</text>
        <input
          class="confirm-settings__input"
          placeholder="如需无谷配方可备注"
          placeholder-class="confirm-settings__placeholder"
          value="{{remark}}"
          bindinput="onRemarkInput"
        />
      </view>
      <view class="confirm-settings__row">
        <text class="confirm-settings__label">配送</text>
        <text class="confirm-settings__value">{{deliveryText}}</text>
      </view>
    </view>

    <view class="confirm-divider"></view>

    <view class="confirm-amounts">
      <view class="confirm-amounts__row">
        <text class="confirm-amounts__label">商品金额</text>
        <text class="confirm-amounts__value">¥{{totalAmount}}</text>
      </view>
      <view class="confirm-amounts__row">
        <text class="confirm-amounts__label">运费</text>
        <text class="confirm-amounts__value">¥{{freight}}</text>
      </view>
      <view class="confirm-amounts__row">
        <text class="confirm-amounts__label">优惠</text>
        <text class="confirm-amounts__value">-¥{{couponDiscount}}</text>
      </view>
      <view class="confirm-amounts__divider"></view>
    </view>

    <view class="confirm-hint">
      <text class="confirm-hint__text">{{orderHint}}</text>
    </view>

    <view class="confirm-bottom-space"></view>
  </view>

  <view class="confirm-submit-bar">
    <view class="confirm-submit-bar__amount">
      <text class="confirm-submit-bar__label">合计</text>
      <text class="confirm-submit-bar__value">¥{{payAmount}}</text>
    </view>
    <button class="confirm-submit-bar__button" bindtap="submitOrder">确认支付</button>
  </view>

  <view wx:if="{{showPaymentSheet}}" class="payment-layer">
    <view class="payment-layer__mask" bindtap="closePaymentLayers"></view>
    <view class="payment-sheet">
      <view class="payment-sheet__handle"></view>
      <view class="payment-sheet__summary">
        <text class="payment-sheet__title">确认支付</text>
        <text class="payment-sheet__sub">订单将以你选择的方式完成支付</text>
      </view>
      <view class="payment-sheet__amount">
        <text class="payment-sheet__amount-value">¥ {{payAmount}}</text>
        <text class="payment-sheet__merchant">宠云精选 Pet Cloud Store · 冻干主粮订单</text>
      </view>
      <view class="payment-sheet__methods">
        <view
          class="payment-sheet__method {{selectedPaymentMethod === item.key ? 'payment-sheet__method--active' : ''}}"
          wx:for="{{paymentMethods}}"
          wx:key="key"
          data-method="{{item.key}}"
          bindtap="selectPaymentMethod"
        >
          <view class="payment-sheet__method-left">
            <view class="payment-sheet__badge payment-sheet__badge--{{item.badgeClass}}">
              <text>{{item.badge}}</text>
            </view>
            <view class="payment-sheet__method-copy">
              <text class="payment-sheet__method-title">{{item.title}}</text>
              <text class="payment-sheet__method-sub">{{item.subtitle}}</text>
            </view>
          </view>
          <view wx:if="{{selectedPaymentMethod === item.key}}" class="payment-sheet__check">✓</view>
          <text wx:else class="payment-sheet__arrow">›</text>
        </view>
      </view>
      <view class="payment-sheet__confirm" bindtap="confirmPaymentMethod">
        <text>确认支付</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showVerification}}" class="verify-layer">
    <view class="verify-layer__mask" bindtap="closePaymentLayers"></view>
    <view wx:if="{{verificationStage === 'face'}}" class="verify-card">
      <text class="verify-card__amount">¥ {{payAmount}}</text>
      <text class="verify-card__method">{{verificationMethodText}}</text>
      <view class="verify-card__panel" bindtap="completeFaceVerification">
        <view class="verify-card__panel-glow"></view>
        <view class="verify-card__panel-ring"></view>
        <view class="verify-card__panel-frame"></view>
        <view class="verify-card__panel-line"></view>
      </view>
      <text class="verify-card__title">确认支付</text>
      <text class="verify-card__sub">注视屏幕以完成身份验证</text>
      <view class="verify-card__dots">
        <view class="verify-card__dot verify-card__dot--active"></view>
        <view class="verify-card__dot verify-card__dot--active"></view>
        <view class="verify-card__dot"></view>
        <view class="verify-card__dot"></view>
        <view class="verify-card__dot"></view>
        <view class="verify-card__dot"></view>
      </view>
      <view class="verify-card__switch" bindtap="completeFaceVerification">
        <text>改用支付密码</text>
      </view>
    </view>

    <view wx:else class="verify-password-card">
      <text class="verify-card__amount">¥ {{payAmount}}</text>
      <text class="verify-card__method">{{verificationMethodText}}</text>

      <view class="verify-password-card__keypad">
        <view
          wx:for="{{passwordKeypadRows}}"
          wx:key="rowIndex"
          wx:for-item="row"
          wx:for-index="rowIndex"
          class="verify-password-card__row"
        >
          <view
            wx:for="{{row}}"
            wx:key="key"
            wx:for-item="keyItem"
            class="verify-password-card__key"
            data-key="{{keyItem.key}}"
            bindtap="handlePasswordKey"
          >
            <text class="verify-password-card__key-text {{keyItem.key === 'delete' ? 'verify-password-card__key-text--muted' : ''}}">
              {{keyItem.label}}
            </text>
          </view>
        </view>
      </view>

      <text class="verify-card__title">请输入支付密码</text>
      <text class="verify-card__sub">支持 6 位数字密码验证</text>
      <view class="verify-password-card__boxes">
        <view wx:for="{{passwordSlots}}" wx:key="*this" class="verify-password-card__box">
          <view wx:if="{{index < paymentPassword.length}}" class="verify-password-card__dot"></view>
        </view>
      </view>
    </view>
  </view>
</view>
