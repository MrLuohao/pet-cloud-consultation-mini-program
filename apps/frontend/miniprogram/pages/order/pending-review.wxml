<!--pages/order/pending-review.wxml-->
<view class="pending-review-container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading && orders.length === 0}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无待评价商品</text>
    <text class="empty-tip">完成订单后来这里分享您的购买体验吧~</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="orderId">
      <!-- 订单头部 -->
      <view class="order-header" bindtap="goToOrderDetail" data-order-id="{{item.orderId}}">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-time">{{item.completeTime}}</text>
      </view>

      <!-- 商品列表 -->
      <view class="product-list">
        <view class="product-item" wx:for="{{item.items}}" wx:for-item="product" wx:key="orderItemId">
          <image class="product-cover" src="{{product.coverUrl}}" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name">{{product.productName}}</text>
            <view class="product-meta">
              <text class="product-price">¥{{product.price}}</text>
              <text class="product-quantity">x{{product.quantity}}</text>
            </view>
          </view>
          <view class="product-action">
            <button class="review-btn" catchtap="goToReview"
              data-order-id="{{item.orderId}}"
              data-order-item-id="{{product.orderItemId}}"
              data-product-id="{{product.productId}}"
              data-product-name="{{product.productName}}"
              data-cover-url="{{product.coverUrl}}"
              data-price="{{product.price}}"
              data-quantity="{{product.quantity}}">
              评价
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{orders.length > 0}}">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{!hasMore}}">没有更多了</text>
  </view>
</view>
