.page {
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: 120rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.store-cover {
  width: 100%;
  height: 400rpx;
  background: #f0e8ff;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  margin: 16rpx;
  padding: 28rpx;
}

.store-info {}

.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.store-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.rating-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #fff9e6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.rating-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #f59e0b;
}

.store-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #6e6e73;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  background: #f3e8ff;
  color: #7c3aed;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.action-row {
  display: flex;
  justify-content: flex-end;
}

.btn-call {
  background: #f3e8ff;
  color: #7c3aed;
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  padding: 20rpx 28rpx 8rpx;
}

.services-list {}

.service-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 0;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f7;
}

.service-item:last-child {
  border-bottom: none;
}

.service-info {
  flex: 1;
}

.service-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 6rpx;
}

.service-desc {
  display: block;
  font-size: 24rpx;
  color: #6e6e73;
  margin-bottom: 8rpx;
}

.service-meta {
  display: flex;
  gap: 8rpx;
}

.service-tag {
  background: #f5f5f7;
  color: #6e6e73;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.service-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
}

.empty-services {
  text-align: center;
  color: #86868b;
  padding: 40rpx;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.06);
}

.btn-booking {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
}
