/* pages/course/course.wxss - 训练课程样式 */

.page {
  min-height: 100vh;
  background: #FFFFFF;
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(24rpx + constant(safe-area-inset-top));
  padding-top: calc(24rpx + env(safe-area-inset-top));
}

.nav-left, .nav-right {
  width: 44rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #1D1D1F;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1D1D1F;
}

/* ==================== 主内容区 ==================== */
.main-content {
  height: 100vh;
}

/* ==================== Banner ==================== */
.course-banner {
  margin: 16rpx 32rpx;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
}

.banner-content {
  display: flex;
  flex-direction: column;
}

.banner-tag {
  display: inline-block;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 课程列表 ==================== */
.course-list {
  padding: 0 32rpx 32rpx;
}

.course-card {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.course-card-hover {
  transform: scale(0.98);
}

.course-image {
  width: 200rpx;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.course-image-pink {
  background: linear-gradient(135deg, #FFE5E5 0%, #FFD1D1 100%);
}

.course-image-blue {
  background: linear-gradient(135deg, #E5E9FF 0%, #D1D9FF 100%);
}

.course-image-green {
  background: linear-gradient(135deg, #E5FFFA 0%, #D1FFF5 100%);
}

.course-image-yellow {
  background: linear-gradient(135deg, #FFF5E5 0%, #FFECD1 100%);
}

.course-emoji {
  font-size: 80rpx;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.3;
}

.course-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.course-lessons, .course-students {
  font-size: 22rpx;
  color: #86868B;
  margin-right: 16rpx;
}

.course-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.course-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF3B30;
}

.course-tag {
  padding: 6rpx 12rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  font-size: 20rpx;
  border-radius: 8rpx;
}

/* ==================== 动画 ==================== */
@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.slide-up {
  animation: slideUp 0.4s ease;
}

.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
}
