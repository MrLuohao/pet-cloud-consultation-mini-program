/* pages/consultation/urgent/index.wxss - 紧急问诊快速响应通道 */
.urgent-page {
  min-height: 100vh;
  background: #fff8f8;
  padding: 0 0 120rpx;
}

/* 紧急头部 */
.urgent-header {
  background: linear-gradient(135deg, #ff3b30, #ff6b35);
  padding: 60rpx 32rpx 48rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.urgent-header::before {
  content: '';
  position: absolute;
  top: -40rpx; right: -40rpx;
  width: 200rpx; height: 200rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

.urgency-badge {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  padding: 12rpx 32rpx;
  margin-bottom: 24rpx;
}
.badge-icon { font-size: 36rpx; }
.badge-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.response-promise {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.response-icon { font-size: 40rpx; }
.response-text {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
}
.blink {
  animation: blink 1s ease-in-out infinite alternate;
}
@keyframes blink {
  from { opacity: 1; }
  to { opacity: 0.6; }
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 1rpx;
}

/* 通用 Section 卡片 */
.section-card {
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.title-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: #aeaeb2;
  flex-shrink: 0;
}
.urgent-dot { background: #ff3b30; }
.required-mark { font-size: 28rpx; color: #ff3b30; }
.optional-mark { font-size: 24rpx; color: #aeaeb2; font-weight: 400; margin-left: 8rpx; }

/* 宠物列表 */
.pet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.pet-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.pet-selected {
  border-color: #ff3b30;
  background: #fff8f8;
}
.pet-avatar {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: #f5f5f7;
  flex-shrink: 0;
}
.pet-info { flex: 1; }
.pet-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}
.pet-breed {
  display: block;
  font-size: 24rpx;
  color: #86868b;
  margin-top: 4rpx;
}
.pet-check {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #ff3b30;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.no-pet { text-align: center; padding: 32rpx 0; }
.no-pet-text { font-size: 26rpx; color: #aeaeb2; }

/* 症状描述 */
.symptom-hints { margin-bottom: 16rpx; }
.hint-label { font-size: 24rpx; color: #86868b; display: block; margin-bottom: 12rpx; }
.hint-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.hint-tag {
  font-size: 22rpx;
  color: #ff3b30;
  background: #fff0ef;
  border: 1rpx solid #ffcccb;
  border-radius: 24rpx;
  padding: 8rpx 20rpx;
}

.symptom-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  line-height: 1.6;
  box-sizing: border-box;
  padding: 16rpx 0;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #aeaeb2;
  margin-top: 8rpx;
}

/* 图片上传 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.image-item {
  position: relative;
  width: 180rpx; height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}
.preview-img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.remove-btn {
  position: absolute;
  top: 6rpx; right: 6rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
.add-image-btn {
  width: 180rpx; height: 180rpx;
  border: 2rpx dashed #ffcccb;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fff8f8;
}
.add-icon { font-size: 40rpx; }
.add-text { font-size: 22rpx; color: #ff3b30; }

/* 提交区域 */
.submit-area {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 32rpx 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}
.safety-tips {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.tips-icon { font-size: 24rpx; flex-shrink: 0; }
.tips-text { font-size: 22rpx; color: #ff9500; line-height: 1.5; }

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff3b30, #ff6b35);
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  letter-spacing: 2rpx;
}
.submit-btn::after { border: none; }
.btn-disabled {
  background: #ccc;
  opacity: 0.7;
}
