/* pages/consultation/create.wxss */
.create-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 医生信息 */
.doctor-info {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.doctor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.doctor-detail {
  flex: 1;
}

.doctor-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 5rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #999;
}

.consultation-fee {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
}

/* 表单 */
.form-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 25rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.label {
  width: 150rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.picker {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 48rpx;
  line-height: 48rpx;
}

.type-selector {
  flex: 1;
  display: flex;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 15rpx;
}

.type-option:last-child {
  margin-right: 0;
}

.type-option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: transparent;
}

.form-item-vertical {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item-vertical .label {
  display: block;
  margin-bottom: 15rpx;
  width: 100%;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 15rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.textarea::placeholder {
  color: #999;
}

/* 图片上传 */
.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.image-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.uploaded-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff6b6b;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.upload-btn {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 50rpx;
  color: #999;
}

.upload-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
}

/* 提交按钮 */
.submit-btn {
  margin: 0 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
}

.submit-btn::after {
  border: none;
}
