.page {
  min-height: 100vh;
  background: #f5f5f7;
}

.type-tabs {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  white-space: nowrap;
}

.tabs-inner {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 8rpx;
}

.tab-item {
  display: inline-block;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #86868b;
  border-bottom: 4rpx solid transparent;
  white-space: nowrap;
}

.tab-item.active {
  color: #667eea;
  border-bottom-color: #667eea;
  font-weight: 600;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.loading-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #86868b;
}

.msg-list {
  padding: 16rpx;
}

.msg-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.msg-item.read {
  opacity: 0.7;
}

.msg-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.bg-purple { background: #f3e8ff; }
.bg-green { background: #d1fae5; }
.bg-orange { background: #fef3c7; }
.bg-blue { background: #dbeafe; }
.bg-pink { background: #fce7f3; }

.msg-body {
  flex: 1;
  min-width: 0;
}

.msg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.msg-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.msg-time {
  font-size: 22rpx;
  color: #86868b;
  flex-shrink: 0;
}

.msg-content {
  font-size: 26rpx;
  color: #6e6e73;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #86868b;
}
