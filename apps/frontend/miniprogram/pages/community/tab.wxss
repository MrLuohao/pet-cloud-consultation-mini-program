page {
  background: #f7f6f4;
}

.community-page {
  min-height: 100vh;
  background: #f7f6f4;
}

.community-top {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 14rpx 16rpx 10rpx;
  background: rgba(247, 246, 244, 0.96);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.search-shell {
  height: 72rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(109, 50, 255, 0.08);
}

.search-placeholder {
  font-size: 24rpx;
  color: #b0acb8;
}

.tab-row {
  display: flex;
  gap: 22rpx;
  margin-top: 18rpx;
  padding: 0 6rpx;
}

.tab-item {
  position: relative;
  padding-bottom: 10rpx;
  font-size: 25rpx;
  color: #a09bab;
}

.tab-item-active {
  color: #25212c;
  font-weight: 600;
}

.tab-item-active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 5rpx;
  border-radius: 999rpx;
  background: #6d32ff;
}

.topic-strip {
  margin-top: 14rpx;
  white-space: nowrap;
}

.topic-list {
  display: inline-flex;
  gap: 10rpx;
  padding-right: 16rpx;
}

.topic-chip {
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #f2eff8;
  font-size: 21rpx;
  color: #7a7190;
}

.feed-scroll {
  height: calc(100vh - 176rpx);
}

.feed-shell {
  padding: 10rpx 16rpx 120rpx;
}

.post-card {
  margin-bottom: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(109, 50, 255, 0.06);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
}

.post-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.identity-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #efeaf8;
  flex-shrink: 0;
}

.identity-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6d32ff;
  font-size: 26rpx;
  font-weight: 600;
}

.identity-main {
  flex: 1;
  min-width: 0;
}

.identity-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f1b27;
}

.identity-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #9a94a4;
  line-height: 1.45;
}

.identity-signature {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #686273;
}

.post-content {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #242029;
}

.post-media {
  margin-top: 16rpx;
}

.post-media-single-img {
  width: 100%;
  height: 300rpx;
  border-radius: 18rpx;
  display: block;
  background: #eee8fb;
}

.post-media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.post-media-grid-img {
  width: calc((100% - 16rpx) / 3);
  height: 180rpx;
  border-radius: 16rpx;
  background: #eee8fb;
}

.topic-row {
  margin-top: 14rpx;
}

.topic-label {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f0ff;
  font-size: 21rpx;
  color: #6d32ff;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1px solid rgba(109, 50, 255, 0.06);
}

.action-item {
  font-size: 21rpx;
  color: #9a94a4;
}

.action-item-active {
  color: #6d32ff;
}

.empty-state {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #918b9c;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  color: #393541;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
}

.list-status {
  padding: 12rpx 0 20rpx;
  text-align: center;
  font-size: 21rpx;
  color: #a09bab;
}

.publish-fab {
  position: fixed;
  right: 24rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: rgba(109, 50, 255, 0.12);
  color: #6d32ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 10rpx 24rpx rgba(109, 50, 255, 0.08);
}
