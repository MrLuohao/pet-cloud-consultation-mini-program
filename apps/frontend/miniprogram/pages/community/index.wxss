page {
  background: #f8f8f8;
}

.community-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.main-scroll {
  height: 100vh;
}

.community-shell {
  padding: 24rpx 24rpx 120rpx;
}

.tab-row,
.topic-row,
.post-header,
.post-actions,
.comment-input-bar,
.modal-header {
  display: flex;
  align-items: center;
}

.search-bar {
  padding: 20rpx 24rpx;
  border-radius: 44rpx;
  background: #ffffff;
  color: #9ca3af;
  font-size: 24rpx;
}

.tab-row {
  gap: 28rpx;
  margin-top: 18rpx;
  padding: 0 8rpx;
}

.tab-item {
  color: #9ca3af;
  font-size: 24rpx;
  font-weight: 500;
}

.tab-item.active {
  color: #1f2937;
  font-weight: 700;
}

.topic-row {
  gap: 10rpx;
  margin-top: 16rpx;
}

.topic-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fbfbfd;
}

.topic-pill text {
  color: #7c8395;
  font-size: 20rpx;
}

.topic-pill.active {
  background: #f3f0ff;
}

.topic-pill.active text {
  color: #6d32ff;
  font-weight: 600;
}

.post-card {
  margin-top: 18rpx;
  padding: 26rpx;
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid #f1f2f5;
}

.post-header {
  align-items: center;
  gap: 16rpx;
}

.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f6f1ff;
  color: #6d32ff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.post-meta {
  flex: 1;
  min-width: 0;
}

.post-name {
  display: block;
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 700;
}

.post-subline {
  display: block;
  margin-top: 4rpx;
  color: #9ca3af;
  font-size: 20rpx;
  line-height: 1.45;
}

.post-signature {
  display: block;
  margin-top: 4rpx;
  color: #b0b6c3;
  font-size: 20rpx;
  line-height: 1.45;
}

.post-content {
  display: block;
  margin-top: 18rpx;
  color: #374151;
  font-size: 28rpx;
  line-height: 1.6;
}

.media-box {
  margin-top: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #eee7ff;
}

.media-image,
.post-video {
  width: 100%;
  height: 320rpx;
}

.post-actions {
  gap: 22rpx;
  margin-top: 18rpx;
}

.action-item text {
  color: #374151;
  font-size: 20rpx;
  font-weight: 600;
}

.action-item.subtle text {
  color: #a0a7b7;
  font-weight: 500;
}

.loading-more,
.empty-state {
  margin-top: 24rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 22rpx;
}

.publish-fab {
  position: fixed;
  right: 28rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 84rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: #efe7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(109, 50, 255, 0.12);
}

.publish-fab text {
  color: #6d32ff;
  font-size: 40rpx;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal-content,
.comment-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
}

.modal-content {
  padding: 32rpx 32rpx 40rpx;
}

.comment-modal {
  max-height: 75vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.modal-title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
}

.modal-close {
  color: #9ca3af;
  font-size: 32rpx;
}

.post-textarea {
  width: 100%;
  min-height: 180rpx;
  color: #1f2937;
  font-size: 26rpx;
  line-height: 1.6;
}

.img-upload-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.upload-thumb,
.add-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
}

.upload-thumb {
  position: relative;
  overflow: hidden;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-thumb {
  border: 2rpx dashed #d1d1d6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-thumb-icon {
  color: #aeaeb2;
  font-size: 48rpx;
}

.modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.char-hint {
  color: #aeaeb2;
  font-size: 20rpx;
}

.publish-btn,
.send-btn {
  background: #6d32ff;
  color: #ffffff;
  border: none;
  border-radius: 36rpx;
}

.publish-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 36rpx;
  font-size: 26rpx;
}

.publish-btn::after,
.send-btn::after {
  border: none;
}

.btn-disabled {
  opacity: 0.65;
}

.comment-list {
  flex: 1;
  padding: 0 32rpx;
}

.comment-loading,
.comment-empty {
  padding: 32rpx 0;
  text-align: center;
  color: #9ca3af;
  font-size: 22rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f7;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
}

.comment-avatar-placeholder {
  background: #f5f5f7;
  color: #86868b;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-body {
  flex: 1;
}

.comment-name,
.comment-text {
  display: block;
  color: #1f2937;
  font-size: 24rpx;
}

.comment-name {
  font-weight: 700;
}

.comment-text {
  margin-top: 8rpx;
  line-height: 1.55;
}

.comment-time {
  display: block;
  margin-top: 8rpx;
  color: #9ca3af;
  font-size: 20rpx;
}

.comment-input-bar {
  gap: 16rpx;
  padding: 20rpx 32rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 36rpx;
  background: #f5f5f7;
  font-size: 24rpx;
}

.send-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  font-size: 24rpx;
}
