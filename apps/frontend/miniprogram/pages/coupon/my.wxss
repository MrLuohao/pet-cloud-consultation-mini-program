/* pages/coupon/my.wxss */
.my-coupon-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* Tab栏 */
.tab-bar {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  display: flex;
  padding: 0 30rpx;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  border-bottom: 0.5px solid rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 32rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active {
  color: #1D1D1F;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

/* 优惠券列表 */
.coupon-list {
  padding: 20rpx 24rpx;
}

/* 优惠券卡片 */
.coupon-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.coupon-card.disabled {
  opacity: 0.6;
}

/* 优惠券主体 */
.coupon-main {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx dashed #eee;
}

/* 左侧金额区域 */
.coupon-amount-section {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-right: 30rpx;
  border-right: 1rpx dashed #eee;
}

.coupon-amount-section.type-reduction {
  color: #ff6b6b;
}

.coupon-amount-section.type-discount {
  color: #ff9500;
}

.amount-row {
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 28rpx;
  font-weight: 600;
}

.amount-value {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.amount-unit {
  font-size: 28rpx;
  font-weight: 600;
  margin-left: 4rpx;
}

.amount-condition {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 右侧信息区域 */
.coupon-info-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 30rpx;
}

.coupon-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.coupon-expire {
  font-size: 24rpx;
  color: #999;
}

/* 优惠券底部操作区 */
.coupon-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.coupon-desc {
  font-size: 24rpx;
  color: #999;
}

.coupon-action {
  display: flex;
  align-items: center;
}

.use-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 36rpx;
  border-radius: 30rpx;
  border: none;
  line-height: 1.2;
}

.use-btn::after {
  border: none;
}

.status-tag {
  font-size: 26rpx;
  padding: 16rpx 36rpx;
}

.status-tag.used {
  color: #999;
}

.status-tag.expired {
  color: #ccc;
}

/* 装饰圆点 */
.coupon-circle {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: #f5f5f5;
  border-radius: 50%;
  top: 50%;
  transform: translateY(-50%);
}

.coupon-circle.left {
  left: -12rpx;
}

.coupon-circle.right {
  right: -12rpx;
}

/* 空状态 */
.empty-state {
  padding-top: 200rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.goto-center-btn {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 24rpx 80rpx;
  border-radius: 44rpx;
  border: none;
}

.goto-center-btn::after {
  border: none;
}
