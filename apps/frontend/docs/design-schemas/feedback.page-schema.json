    {
      "sectionKey": "feedback_form",
      "api": "GET /api/feedback/template",
      "fields": ["template.bodyPlaceholder", "template.tip"]
    },
    {
      "sectionKey": "contact_section",
      "api": "GET /api/user/profile",
      "fields": ["user.contact.wechat", "user.contact.phone"]
    }
  ],
  "actions": [
    { "name": "goBack", "target": "wx.navigateBack", "sectionKey": "page_header" },
    { "name": "selectFeedbackType", "target": "client/select-feedback-type", "sectionKey": "feedback_types" },
    { "name": "fillFeedback", "target": "client/update-text-input", "sectionKey": "feedback_form" },
    { "name": "fillContact", "target": "client/auto-fill-contact", "sectionKey": "contact_section" },
    { "name": "attachScreenshot", "target": "client/multi-image-picker", "sectionKey": "upload_card" },
    { "name": "submitFeedback", "target": "POST /api/feedback", "sectionKey": "submit" }
  ],
  "verification": {
    "sourceScreenshotNodeId": "orfEX",
    "criticalCheckpoints": [
      "Status bar and header share the same vertical rhythm and spacing as the frame.",
      "Intro and form cards stay gradient and white with rounded corners, chips, and generous padding.",
      "Submit button remains the full-width purple CTA above the upload hint to keep the action prominent.",
      "Upload section keeps the guidance copy and pill-style button for attaching up to three screenshots."
    ]
  }
