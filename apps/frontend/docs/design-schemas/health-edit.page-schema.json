  "verification": {
    "sourceScreenshotNodeId": "kabmm",
    "criticalCheckpoints": [
      "create and edit states share one calm single-page card form language instead of modal-heavy CRUD editing",
      "identity preview card always anchors the top of the form before any editable fields",
      "form cards separate basic info, detail notes, clinic attachments and reminder suggestions into stacked editorial blocks",
      "edit state keeps a visible destructive path while create state uses a softer secondary cancel action"
    ]
