  "dataBindings": [
    {
      "sectionKey": "identity_preview_card",
      "api": "GET /api/pets/{petId}",
      "fields": ["id", "name", "breed", "ageText", "weight", "latestRecordTime", "nextReviewDate", "timelineStatusLabel"]
    },
    {
      "sectionKey": "basic_info_card",
      "api": "GET /api/pets/list | GET /api/health/{recordId}",
      "fields": ["petOptions[].id", "petOptions[].name", "petId", "recordType", "title"]
    },
    {
      "sectionKey": "detail_card",
      "api": "GET /api/health/{recordId}",
      "fields": ["content", "contentHint", "recordDate", "nextDate"]
    },
    {
      "sectionKey": "clinic_card",
      "api": "GET /api/health/{recordId}",
      "fields": ["hospitalName", "doctorName", "images[]", "attachmentHint"]
    },
    {
      "sectionKey": "reminder_suggest_card",
      "fields": ["reminderPreset", "reminderPresetOptions[]"]
    }
