{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://petcloud.local/design-schemas/page-schema.contract.json",
  "title": "PencilPageSchema",
  "type": "object",
  "required": [
    "meta",
    "layout",
    "tokens",
    "sections",
    "dataBindings",
    "actions",
    "verification"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["pageKey", "platform", "penFile", "frameId", "frameName"],
      "properties": {
        "pageKey": { "type": "string" },
        "platform": { "type": "string", "enum": ["wechat-miniprogram"] },
        "penFile": { "type": "string" },
        "frameId": { "type": "string" },
        "frameName": { "type": "string" },
        "variantFrameIds": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "required": ["background", "contentPadding", "sectionGap", "safeAreaTop"],
      "properties": {
        "background": { "type": "string" },
        "contentPadding": {
          "type": "array",
          "items": { "type": ["number", "string"] },
          "minItems": 4,
          "maxItems": 4
        },
        "sectionGap": { "type": ["number", "string"] },
        "safeAreaTop": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "tokens": {
      "type": "object",
      "required": ["colors", "radius", "typography"],
      "properties": {
        "colors": { "type": "object" },
        "radius": { "type": "object" },
        "typography": { "type": "object" }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "type", "sourceNodeId"],
        "properties": {
          "key": { "type": "string" },
          "type": { "type": "string" },
          "sourceNodeId": { "type": "string" },
          "title": { "type": "string" },
          "copy": { "type": "array", "items": { "type": "string" } },
          "layout": { "type": "object" },
          "children": {
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "additionalProperties": true
      }
    },
    "dataBindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sectionKey", "fields"],
        "properties": {
          "sectionKey": { "type": "string" },
          "api": { "type": "string" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "target"],
        "properties": {
          "name": { "type": "string" },
          "target": { "type": "string" },
          "sectionKey": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "verification": {
      "type": "object",
      "required": ["sourceScreenshotNodeId", "criticalCheckpoints"],
      "properties": {
        "sourceScreenshotNodeId": { "type": "string" },
        "criticalCheckpoints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
