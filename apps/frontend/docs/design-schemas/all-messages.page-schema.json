      "sectionKey": "priority_bar",
      "api": "GET /api/messages/priority",
      "fields": ["prioritySummary.title", "prioritySummary.items[].text", "prioritySummary.cta"]
    },
    {
      "sectionKey": "chat_card",
      "api": "GET /api/messages/chats",
